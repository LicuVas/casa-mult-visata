---
// Hub „Cartiere din Piatra Neamț" — pagină-pilon care leagă ghidurile de cartier
// și distribuie autoritate internă. ADITIV. Numără ofertele active per cartier.
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { cartiere } from '../data/cartiere';
import { normZone, parseLocalitate } from '../utils/localitate';

const all = await getCollection('proprietati');
const countFor = (zoneMatch: string[]) =>
  all.filter((p) => zoneMatch.some((z) => normZone(z) === normZone(p.data.zone || parseLocalitate(p.data.localitate)?.sat)) && (p.data.listingStatus || 'Activ') !== 'Retras').length;

const items = cartiere.map((c) => ({ ...c, count: countFor(c.zoneMatch) }));

const origin = 'https://casamultvisata.ro';
const extraSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      '@id': `${origin}/cartiere-piatra-neamt/#page`,
      'name': 'Cartiere din Piatra Neamț — ghid pentru cumpărători',
      'description': 'Ghid pe cartiere al Piatra Neamț: Centru, Precista, Mărăței, Dărmănești, 1 Mai — caracter, orientare și proprietăți de vânzare în fiecare zonă.',
      'url': `${origin}/cartiere-piatra-neamt/`,
      'isPartOf': { '@id': `${origin}/#website` },
      'about': { '@id': `${origin}/#agent` },
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Acasă', 'item': `${origin}/` },
        { '@type': 'ListItem', 'position': 2, 'name': 'Cartiere Piatra Neamț', 'item': `${origin}/cartiere-piatra-neamt/` },
      ],
    },
    {
      '@type': 'ItemList',
      'name': 'Cartiere Piatra Neamț',
      'numberOfItems': items.length,
      'itemListElement': items.map((c, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'url': `${origin}/cartiere/${c.slug}/`,
        'name': c.name,
      })),
    },
  ],
};
---
<Layout
  title="Cartiere din Piatra Neamț — Ghid pe Zone | Casa Mult Visată"
  description="Ghid pe cartiere al Piatra Neamț: Centru, Precista, Mărăței, Dărmănești, 1 Mai. Cum e fiecare zonă și ce proprietăți sunt de vânzare — agent Cozma Vasile."
  canonicalPath="/cartiere-piatra-neamt/"
  extraSchema={extraSchema}
>
  <div class="container">
    <nav class="breadcrumb" aria-label="Firimituri">
      <a href="/">Acasă</a> › <span>Cartiere Piatra Neamț</span>
    </nav>

    <div class="page-header">
      <p class="label">Ghid pe zone</p>
      <h1>Cartierele din Piatra Neamț</h1>
      <p class="intro">Fiecare cartier are propriul caracter, propriile prețuri și propriul tip de cumpărător. Mai jos găsești o orientare scurtă pentru fiecare zonă și proprietățile pe care le am acum acolo — ca să pornești căutarea din locul potrivit.</p>
    </div>

    <div class="cartier-grid">
      {items.map((c) => (
        <a class="cartier-card" href={`/cartiere/${c.slug}/`}>
          <h2>{c.name}</h2>
          <p class="cartier-count">{c.count > 0 ? `${c.count} ${c.count === 1 ? 'ofertă' : 'oferte'} acum` : 'Întreabă de oferte'}</p>
          <p class="cartier-intro">{c.intro}</p>
          <span class="cartier-link">Vezi cartierul {c.name} →</span>
        </a>
      ))}
    </div>

    <section class="silo-copy">
      <h2>Nu știi din ce cartier să pornești?</h2>
      <p>Spune-mi bugetul, tipul de locuință și ce contează pentru tine — liniște, apropiere de centru, școli, acces auto — și îți recomand zonele care se potrivesc, cu oferte concrete. Caut activ și proprietăți care nu au ajuns încă pe site. Pentru cumpărători, comisionul meu este <strong>0%</strong>.</p>
      <p class="silo-cta">Vezi <a href="/proprietati">tot portofoliul</a> sau <a href="/contact">contactează-mă direct</a>.</p>
    </section>
  </div>
</Layout>

<style>
  .breadcrumb { font-size: 0.85rem; color: var(--muted, #667); margin: 1.5rem 0 0.5rem; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .cartier-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .cartier-card { display: block; padding: 1.5rem; border: 1px solid var(--border, #e6e2db); border-radius: 14px; text-decoration: none; color: inherit; transition: box-shadow .2s, transform .2s; background: var(--card-bg, #fff); }
  .cartier-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,.07); transform: translateY(-2px); }
  .cartier-card h2 { margin: 0 0 .25rem; font-size: 1.3rem; }
  .cartier-count { margin: 0 0 .75rem; font-size: .8rem; letter-spacing: .03em; text-transform: uppercase; color: var(--accent, #9a7b4f); }
  .cartier-intro { line-height: 1.6; font-size: .95rem; margin: 0 0 1rem; }
  .cartier-link { font-weight: 600; font-size: .9rem; }
  .silo-copy { max-width: 760px; margin: 3.5rem 0 1rem; }
  .silo-copy h2 { margin-top: 1.75rem; }
  .silo-copy p { line-height: 1.7; }
  .silo-cta { margin-top: 1.75rem; }
</style>
