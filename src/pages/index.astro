---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProperties = await getCollection('proprietati');
const featuredProperties = allProperties.slice(0, 3);

// Helper function to format price
const formatPrice = (price: number, currency: string) => {
  return new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(price);
};
---

<Layout title="Casa Mult Visată — Agenție Imobiliară Piatra Neamț" description="Agent imobiliar Cozma Vasile. Cumperi, vinzi sau închiriezi în Piatra Neamț? Experiență și seriozitate. Comision 0% la cumpărare pentru majoritatea proprietăților.">
	
	<!-- HERO -->
	<section class="hero-cover">
		<div class="hero-cover-text reveal">
			<p class="label">Agenție imobiliară · Piatra Neamț</p>
			<h1 class="headline">Găsește Casa<br>Mult Visată</h1>
			<p class="subtitle">Proprietăți de vânzare și închiriere în Piatra Neamț și împrejurimi. Experiență, seriozitate și dedicare pentru fiecare client.</p>
			<div class="hero-cta">
				<a href="/proprietati" class="btn-primary">Vezi Proprietăți</a>
				<a href="https://wa.me/40747814263?text=Bună%20ziua!%20Vreau%20informații%20despre%20o%20proprietate." class="btn-whatsapp" target="_blank" rel="noopener">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					WhatsApp
				</a>
			</div>
		</div>
		<figure class="hero-cover-image">
			<img src="/images/hero.png" alt="Proprietăți imobiliare în Piatra Neamț" loading="eager">
			<figcaption>Piatra Neamț — Orașul la poalele Ceahlăului</figcaption>
		</figure>
	</section>

	<hr class="rule">

	<!-- PROPRIETĂȚI RECOMANDATE -->
	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="section-header reveal">
				<hr>
				<p class="label">Proprietăți recomandate</p>
				<h2>Oferte Selectate</h2>
			</div>

			<div class="editorial-grid">
				{featuredProperties.map((prop, index) => {
					// Make the first one large (feature-main)
					const isMain = index === 0;
					const itemClass = isMain ? "property-editorial feature-main reveal" : "property-editorial feature-side reveal";
					const imageSrc = prop.data.featuredImage || (prop.data.propertyType === 'Apartament' ? '/images/apartament.png' : prop.data.propertyType === 'Casă' ? '/images/casa.png' : '/images/teren.png');
					
					let metaDetails = [];
					if (prop.data.rooms) metaDetails.push(`${prop.data.rooms} camere`);
					if (prop.data.bathrooms) metaDetails.push(`${prop.data.bathrooms} băi`);
					if (prop.data.surface) metaDetails.push(`${prop.data.surface} mp`);
					if (prop.data.landSurface && prop.data.propertyType === 'Teren') metaDetails.push(`Teren: ${prop.data.landSurface} mp`);
					
					return (
						<article class={itemClass}>
							<a href={`/proprietati/${prop.id}`}>
								<img src={imageSrc} alt={prop.data.title}>
							</a>
							<div class="caption">
								<span class="tag">
									De {prop.data.status.toLowerCase()} 
									{prop.data.exclusive ? " · Exclusiv" : ""}
									{prop.data.comisionZero ? " · Comision 0%" : ""}
								</span>
								<h3><a href={`/proprietati/${prop.id}`}>{prop.data.title}</a></h3>
								<span class="price">
									{prop.data.pricePerUnit ? prop.data.pricePerUnit : formatPrice(prop.data.price, prop.data.currency)}
								</span>
								<p class="meta">{prop.data.zone ? `${prop.data.zone} · ` : ""}{metaDetails.join(" · ")}</p>
							</div>
						</article>
					)
				})}
			</div>

			<div style="text-align:right; margin-top:2rem;">
				<a href="/proprietati" class="editorial-link">Vezi toate proprietățile &rarr;</a>
			</div>
		</div>
	</section>

	<!-- PULL QUOTE -->
	<div class="container">
		<div class="pull-quote reveal">
			<blockquote>&ldquo;Fiecare casă are o poveste. Te ajut să o găsești pe a ta.&rdquo;</blockquote>
			<cite>Cozma Vasile, Agent Imobiliar</cite>
		</div>
	</div>

	<!-- SERVICII PREVIEW -->
	<section class="services-editorial">
		<div class="container">
			<div class="section-header reveal">
				<hr>
				<p class="label">Ce pot face pentru tine</p>
				<h2>Servicii</h2>
			</div>

			<div class="service-item reveal">
				<h3>Vânzare &amp; Cumpărare</h3>
				<p>Te asist în întregul proces — de la evaluarea proprietății, fotografiere și promovare, până la negociere și semnarea actelor la notar.</p>
			</div>
			<div class="service-item reveal">
				<h3>Închirieri</h3>
				<p>Găsesc chiriași de încredere sau proprietăți potrivite nevoilor tale. Contract, proces-verbal de predare și suport continuu.</p>
			</div>
			<div class="service-item reveal">
				<h3>Consultanță Imobiliară</h3>
				<p>Evaluare gratuită a proprietății tale. Analiză de piață pentru zona Piatra Neamț și sfaturi bazate pe experiența mea în domeniu.</p>
			</div>

			<div style="margin-top:2rem;">
				<a href="/servicii" class="editorial-link">Toate serviciile &rarr;</a>
			</div>
		</div>
	</section>

	<!-- STATS -->
	<section class="dark-section">
		<div class="container">
			<div class="stats-grid reveal">
				<div class="stat">
					<span class="stat-number">10+</span>
					<span class="stat-label">Ani experiență<br>în imobiliare</span>
				</div>
				<div class="stat">
					<span class="stat-number">200+</span>
					<span class="stat-label">Tranzacții<br>finalizate</span>
				</div>
				<div class="stat">
					<span class="stat-number">98%</span>
					<span class="stat-label">Clienți<br>mulțumiți</span>
				</div>
				<div class="stat">
					<span class="stat-number">30</span>
					<span class="stat-label">Zile — timp mediu<br>de vânzare</span>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<div class="container">
		<div class="cta-editorial reveal">
			<h2>Vrei să Vinzi sau să Închiriezi?</h2>
			<p>Listează proprietatea ta cu un expert. Ajunge la potențiali cumpărători și chiriași din Piatra Neamț și împrejurimi.</p>
			<a href="/contact">Contactează-mă &rarr;</a>
		</div>
	</div>

	<!-- ZONE PIATRA NEAMT -->
	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="section-header reveal">
				<hr>
				<p class="label">Zone acoperite</p>
				<h2>Piatra Neamț și Împrejurimi</h2>
			</div>
			<div class="zones-grid reveal">
				<div class="zone-tag">Centru</div>
				<div class="zone-tag">Precista</div>
				<div class="zone-tag">Mărăței</div>
				<div class="zone-tag">Dărmănești</div>
				<div class="zone-tag">1 Mai</div>
				<div class="zone-tag">Calea Romanului</div>
				<div class="zone-tag">Obor</div>
				<div class="zone-tag">Dobreni</div>
				<div class="zone-tag">Bodești</div>
				<div class="zone-tag">Dumbrava Roșie</div>
				<div class="zone-tag">Alexandru cel Bun</div>
				<div class="zone-tag">Județul Neamț</div>
			</div>
		</div>
	</section>

</Layout>
