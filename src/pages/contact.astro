---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Casa Mult Visată — Agent Imobiliar Piatra Neamț" description="Contactează-l pe Cozma Vasile — agent imobiliar Piatra Neamț. Telefon: 0747 814 263. Email: vascozma@gmail.com. WhatsApp disponibil.">
	
	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="page-header reveal">
				<p class="label">Hai să vorbim</p>
				<h1>Contact</h1>
				<p class="intro">Sunt aici să te ajut cu orice întrebare legată de imobiliare. Prima consultație e gratuită.</p>
			</div>

			<div class="contact-grid reveal">
				<div>
					<h3 style="font-family:var(--font-display); font-size:1.5rem; font-weight:500; margin-bottom:2rem;">Trimite-mi un Mesaj</h3>
					<!-- Replace with real Formspree endpoint -->
					<form action="https://formspree.io/f/placeholder" method="POST" id="contact-form">
						<div class="form-group">
							<label for="name">Nume complet</label>
							<input type="text" id="name" name="name" required placeholder="Ion Popescu">
						</div>
						<div class="form-group">
							<label for="phone">Telefon</label>
							<input type="tel" id="phone" name="phone" required placeholder="07XX XXX XXX">
						</div>
						<div class="form-group">
							<label for="email">Email</label>
							<input type="email" id="email" name="email" placeholder="email@exemplu.ro">
						</div>
						<div class="form-group">
							<label for="interest">Interes</label>
							<select id="interest" name="interest">
								<option>Vreau să cumpăr</option>
								<option>Vreau să vând</option>
								<option>Vreau să închiriez</option>
								<option>Caut chiriași</option>
								<option>Evaluare proprietate</option>
								<option>Altceva</option>
							</select>
						</div>
						<div class="form-group">
							<label for="message">Mesaj</label>
							<textarea id="message" name="message" placeholder="Descrie pe scurt ce cauți..."></textarea>
						</div>
						<button type="submit" class="btn-primary" style="width:100%; text-align:center;">Trimite Mesaj</button>
					</form>
				</div>

				<div>
					<div class="contact-info-card">
						<h3>Informații Contact</h3>
						<div class="contact-info-item">
							<h4>Agent</h4>
							<p>Cozma Vasile</p>
						</div>
						<div class="contact-info-item">
							<h4>Telefon</h4>
							<a href="tel:0747814263">0747 814 263</a>
						</div>
						<div class="contact-info-item">
							<h4>Email</h4>
							<a href="mailto:vascozma@gmail.com">vascozma@gmail.com</a>
						</div>
						<div class="contact-info-item">
							<h4>WhatsApp</h4>
							<a href="https://wa.me/40747814263" target="_blank" rel="noopener" style="color:var(--accent-green); font-weight:500;">Deschide WhatsApp →</a>
						</div>
						<div class="contact-info-item">
							<h4>Zonă de activitate</h4>
							<p>Piatra Neamț, Județul Neamț</p>
						</div>
						<hr style="border:none; border-top:1px solid var(--rule-color); margin:1.5rem 0;">
						<div class="contact-info-item">
							<h4>Social Media</h4>
							<p>
								<a href="https://www.facebook.com/profile.php?id=100075290402563" target="_blank" rel="noopener">Facebook</a> · 
								<a href="https://www.instagram.com/cozma276/" target="_blank" rel="noopener">Instagram</a> · 
								<a href="https://www.tiktok.com/@cozmavasile_si_ana_lory" target="_blank" rel="noopener">TikTok</a>
							</p>
						</div>
						<hr style="border:none; border-top:1px solid var(--rule-color); margin:1.5rem 0;">
						<div class="contact-info-item">
							<h4>Program</h4>
							<p>Luni – Vineri: 9:00 – 19:00</p>
							<p>Sâmbătă: 10:00 – 15:00</p>
							<p>Duminică: La cerere</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

</Layout>
