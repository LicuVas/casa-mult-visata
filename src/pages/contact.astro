---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Casa Mult Visată — Cozma Vasile Agent Piatra Neamț" description="Contactează-mă pentru o consultanță gratuită. Telefon, WhatsApp, formular online. Răspund rapid." ogImage="/images/hero.webp">

	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="page-header reveal">
				<p class="label">Hai să vorbim</p>
				<h1>Contact</h1>
				<p class="intro">Sunt aici să te ajut cu orice întrebare legată de imobiliare. Prima consultație e gratuită.</p>
			</div>

			<div class="contact-grid reveal">
				<div>
					<h3 style="font-family:var(--font-display); font-size:1.5rem; font-weight:500; margin-bottom:2rem;">Trimite-mi un Mesaj</h3>
					<form
						name="contact"
						method="POST"
						action="/multumesc"
						data-netlify="true"
						netlify-honeypot="bot-field"
						id="contact-form"
					>
						<input type="hidden" name="form-name" value="contact">
						<p hidden>
							<label>Don't fill: <input name="bot-field"></label>
						</p>

						<div class="form-group">
							<label for="name">Nume complet</label>
							<input type="text" id="name" name="name" required aria-required="true" autocomplete="name" enterkeyhint="next" placeholder="Ion Popescu">
						</div>
						<div class="form-group">
							<label for="phone">Telefon</label>
							<input type="tel" id="phone" name="phone" required aria-required="true" autocomplete="tel" inputmode="tel" enterkeyhint="next" pattern="[0-9 +()-]{7,20}" placeholder="07XX XXX XXX">
						</div>
						<div class="form-group">
							<label for="email">Email</label>
							<input type="email" id="email" name="email" autocomplete="email" inputmode="email" enterkeyhint="next" placeholder="email@exemplu.ro">
						</div>
						<div class="form-group">
							<label for="interest">Interes</label>
							<select id="interest" name="interest">
								<option>Vreau să cumpăr</option>
								<option>Vreau să vând</option>
								<option>Vreau să închiriez</option>
								<option>Caut chiriași</option>
								<option>Evaluare proprietate</option>
								<option>Altceva</option>
							</select>
						</div>
						<div class="form-group" id="proprietate-group" style="display:none;">
							<label for="proprietate">Proprietate de interes</label>
							<input type="text" id="proprietate" name="proprietate" readonly>
						</div>
						<div class="form-group">
							<label for="message">Mesaj</label>
							<textarea id="message" name="message" required aria-required="true" minlength="10" autocomplete="off" enterkeyhint="send" placeholder="Descrie pe scurt ce cauți..."></textarea>
						</div>
						<div class="cmv-gdpr">
							<input type="checkbox" id="gdpr-consent" name="gdpr-consent" required aria-required="true" value="da">
							<label for="gdpr-consent">
								Sunt de acord ca datele mele să fie folosite pentru a primi un răspuns. Am citit
								<a href="/confidentialitate/" target="_blank" rel="noopener">Politica de Confidențialitate</a>.
							</label>
						</div>
						<button type="submit" id="submit-btn" class="btn-primary" style="width:100%; text-align:center;">Trimite Mesaj</button>
					</form>
				</div>

				<div>
					<div class="contact-info-card">
						<h3>Informații Contact</h3>
						<div class="contact-info-item">
							<h4>Agent</h4>
							<p>Cozma Vasile</p>
						</div>
						<div class="contact-info-item">
							<h4>Telefon</h4>
							<a href="tel:0747814263">0747 814 263</a>
						</div>
						<div class="contact-info-item">
							<h4>Email</h4>
							<a href="mailto:vascozma@gmail.com">vascozma@gmail.com</a>
						</div>
						<div class="contact-info-item">
							<h4>WhatsApp</h4>
							<a href="https://wa.me/40747814263" target="_blank" rel="noopener" style="color:var(--accent-green); font-weight:500;">Deschide WhatsApp →</a>
						</div>
						<div class="contact-info-item">
							<h4>Zonă de activitate</h4>
							<p>Piatra Neamț, Județul Neamț</p>
						</div>
						<hr style="border:none; border-top:1px solid var(--rule-color); margin:1.5rem 0;">
						<div class="contact-info-item">
							<h4>Social Media</h4>
							<p>
								<a href="https://www.facebook.com/profile.php?id=100075290402563" target="_blank" rel="noopener">Facebook</a> ·
								<a href="https://www.instagram.com/cozma276/" target="_blank" rel="noopener">Instagram</a> ·
								<a href="https://www.tiktok.com/@cozmavasile_si_ana_lory" target="_blank" rel="noopener">TikTok</a>
							</p>
						</div>
						<hr style="border:none; border-top:1px solid var(--rule-color); margin:1.5rem 0;">
						<div class="contact-info-item">
							<h4>Program</h4>
							<p>Luni – Vineri: 9:00 – 19:00</p>
							<p>Sâmbătă: 10:00 – 15:00</p>
							<p>Duminică: La cerere</p>
						</div>
					</div>

					<div style="margin-top:2rem;">
						<div class="cmv-map-placeholder" id="map-placeholder" data-map-loaded="false">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
								<circle cx="12" cy="10" r="3"/>
							</svg>
							<p>Harta este oferită de Google Maps și poate seta cookie-uri. Apasă butonul pentru a o încărca.</p>
							<button type="button" id="load-map-btn" class="btn-primary">Afișează harta</button>
							<p style="font-size:0.8rem;"><a href="/cookies/">Politica de Cookies</a></p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function () {
			var form = document.getElementById('contact-form');
			var phone = document.getElementById('phone');
			var message = document.getElementById('message');
			var submitBtn = document.getElementById('submit-btn');
			var interest = document.getElementById('interest');
			var propGroup = document.getElementById('proprietate-group');
			var propInput = document.getElementById('proprietate');

			// Helper: select option by visible text
			function selectInterestByText(targetText) {
				if (!interest || !targetText) return;
				for (var i = 0; i < interest.options.length; i++) {
					if (interest.options[i].text === targetText) {
						interest.selectedIndex = i;
						return;
					}
				}
			}

			// Pre-fill from ?proprietate= and ?interes=
			try {
				var params = new URLSearchParams(window.location.search);
				var prop = params.get('proprietate');
				var interes = params.get('interes');

				if (prop) {
					propInput.value = prop;
					propGroup.style.display = '';
					if (!message.value) {
						message.value = 'Bună ziua, vreau mai multe informații despre proprietatea: [' + prop + ']. Vă rog să mă contactați.';
					}
					selectInterestByText('Vreau să cumpăr');
				}

				if (interes) {
					var interesMap = {
						'cumparare': 'Vreau să cumpăr',
						'vanzare': 'Vreau să vând',
						'inchiriere-vreau': 'Vreau să închiriez',
						'inchiriere-caut': 'Caut chiriași',
						'evaluare': 'Evaluare proprietate',
						'altceva': 'Altceva'
					};
					var mapped = interesMap[interes];
					if (mapped) selectInterestByText(mapped);
				}
			} catch (e) {}

			// Custom RO validation messages
			function setMessages() {
				var name = document.getElementById('name');
				if (name) {
					name.addEventListener('invalid', function () {
						name.setCustomValidity('Te rog completează numele tău.');
					});
					name.addEventListener('input', function () { name.setCustomValidity(''); });
				}
				if (phone) {
					phone.addEventListener('invalid', function () {
						if (phone.validity.valueMissing) {
							phone.setCustomValidity('Te rog completează numărul de telefon.');
						} else {
							phone.setCustomValidity('Introdu un număr valid (ex: 0747 814 263 sau +40747814263).');
						}
					});
					phone.addEventListener('input', function () { phone.setCustomValidity(''); });
				}
				if (message) {
					message.addEventListener('invalid', function () {
						if (message.validity.valueMissing) {
							message.setCustomValidity('Te rog scrie un mesaj scurt.');
						} else if (message.validity.tooShort) {
							message.setCustomValidity('Mesajul trebuie să aibă cel puțin 10 caractere.');
						}
					});
					message.addEventListener('input', function () { message.setCustomValidity(''); });
				}
			}
			setMessages();

			// Submit state
			if (form && submitBtn) {
				form.addEventListener('submit', function () {
					submitBtn.disabled = true;
					submitBtn.textContent = 'Se trimite...';
				});
			}

			// GDPR checkbox validation message
			var gdpr = document.getElementById('gdpr-consent');
			if (gdpr) {
				gdpr.addEventListener('invalid', function () {
					gdpr.setCustomValidity('Te rog confirmă că ești de acord cu Politica de Confidențialitate.');
				});
				gdpr.addEventListener('change', function () { gdpr.setCustomValidity(''); });
			}

			// Click-to-load Google Maps (GDPR — no third-party request before user consent)
			var mapBtn = document.getElementById('load-map-btn');
			var mapHolder = document.getElementById('map-placeholder');
			function loadMap() {
				if (!mapHolder || mapHolder.dataset.mapLoaded === 'true') return;
				var iframe = document.createElement('iframe');
				iframe.src = 'https://www.google.com/maps?q=Piatra+Neam%C8%9B,+Jude%C8%9Bul+Neam%C8%9B,+Rom%C3%A2nia&output=embed';
				iframe.title = 'Piatra Neamț pe Google Maps';
				iframe.width = '100%';
				iframe.height = '300';
				iframe.style.border = '0';
				iframe.style.display = 'block';
				iframe.loading = 'lazy';
				iframe.referrerPolicy = 'no-referrer-when-downgrade';
				mapHolder.innerHTML = '';
				mapHolder.appendChild(iframe);
				mapHolder.style.padding = '0';
				mapHolder.style.background = 'transparent';
				mapHolder.style.border = '0';
				mapHolder.dataset.mapLoaded = 'true';
			}
			if (mapBtn) mapBtn.addEventListener('click', loadMap);
			// Auto-load if user previously accepted cookies (and on future consent events)
			function autoLoadIfConsented() {
				try {
					var m = document.cookie.match(/(?:^|;\s*)cmv_consent=([^;]+)/);
					if (m && decodeURIComponent(m[1]) === 'accepted') loadMap();
				} catch (e) {}
			}
			autoLoadIfConsented();
			window.addEventListener('cmv:consent', function (ev) {
				if (ev && ev.detail && ev.detail.value === 'accepted') loadMap();
			});
		});
	</script>

</Layout>
