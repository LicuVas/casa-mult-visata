---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina nu există · Casa Mult Visată" description="Pagina căutată nu a fost găsită. Întoarce-te acasă sau explorează proprietățile disponibile în Piatra Neamț." noIndex={true}>

	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="page-header reveal" style="text-align:center; max-width:42rem; margin:0 auto;">
				<p class="label">Eroare 404</p>
				<h1 style="font-family:var(--font-display); font-weight:300;">
					<span style="color:var(--accent);">Pagina aceasta</span> s-a rătăcit
				</h1>
				<p class="intro" style="margin-top:1.5rem;">
					Linkul pe care l-ai urmat nu mai duce nicăieri, sau poate proprietatea a fost deja vândută. Hai să te ajut să găsești ce cauți.
				</p>

				<div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:2.5rem;">
					<a href="/" class="btn-primary">Înapoi acasă</a>
					<a href="/proprietati" class="btn-primary" style="background:var(--accent-green);">Vezi proprietăți</a>
				</div>

				<p style="margin-top:3rem; font-family:var(--font-accent); color:var(--text-secondary); font-size:0.95rem;">
					Sau sună direct: <a href="tel:0747814263" style="color:var(--accent); text-decoration:none; font-weight:500;">0747 814 263</a>
				</p>
			</div>
		</div>
	</section>

</Layout>
