---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import cartierCanon from '../../tools/cartier_canon.json';

const allProperties = await getCollection('proprietati');

// Helper: format price
const formatPrice = (price: number, currency: string) => {
  return new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(price);
};

// Region detection: Piatra Neamț (oraș) vs Împrejurimi (sate / comune)
const isPN = (loc?: string): boolean => !!loc && /Piatra Neam/i.test(loc);

// SSOT: derive pnZones, impZones, ZONE_CENTROIDS from tools/cartier_canon.json.
// Adding a new neighborhood requires editing canon.json only — dropdown, centroids,
// and map markers update automatically. Also unifies with `[slug].astro`.
type CanonEntry = { name: string; coords: [number, number]; aliases?: string[] };
const canonPN = (cartierCanon.cartiere as CanonEntry[]).map(c => c.name);
const canonImp = (cartierCanon.outsidePN_localitati as CanonEntry[]).map(c => c.name);

// Aliases lookup: search "Gara Veche" finds Obor properties, "Centrul orașului" finds Centru.
const ZONE_ALIASES: Record<string, string[]> = Object.fromEntries(
  (cartierCanon.cartiere as CanonEntry[])
    .filter(c => Array.isArray(c.aliases) && c.aliases.length > 0)
    .map(c => [c.name, c.aliases as string[]])
);

// Defense in depth: include any zone strings that appear in actual property data but
// aren't in canon (e.g. hand-edit slipping a new zone before canon.json catches up).
// Without this, such properties would be invisible to the zone filter dropdown.
const dataZones = Array.from(new Set(
  allProperties.map(p => p.data.zone).filter((z): z is string => typeof z === 'string' && z.trim().length > 0)
));
const orphanZones = dataZones.filter(z => !canonPN.includes(z) && !canonImp.includes(z));
// Orphans are classified by region of their FIRST property using that zone.
const orphanPN: string[] = [];
const orphanImp: string[] = [];
for (const z of orphanZones) {
  const sample = allProperties.find(p => p.data.zone === z);
  const region = sample && /Piatra Neam/i.test(sample.data.location) ? 'PN' : 'imprejurimi';
  if (region === 'PN') orphanPN.push(z); else orphanImp.push(z);
}

const pnZones = [...canonPN, ...orphanPN].sort((a, b) => a.localeCompare(b, 'ro'));
const impZones = [...canonImp, ...orphanImp].sort((a, b) => a.localeCompare(b, 'ro'));

// All properties are rendered into the DOM so the "Include vândute/retrase" checkbox
// can opt them back in client-side. Vândut/Retras articles get inline `display:none`
// at render time (see `initialHidden` below) — that prevents FOUC without removing
// them from DOM. SEO: detail pages of Vândut/Retras carry `noIndex` meta.
const visibleProperties = allProperties;

const activeCount = allProperties.filter(p => {
  const ls = p.data.listingStatus || 'Activ';
  // Vândut/Închiriat/Rezervat rămân vizibile (cu bandă) ca dovadă socială; doar Retras e scos.
  return ls !== 'Retras';
}).length;
const totalCount = activeCount;
const totalAll = allProperties.length;

// Bbox guard: reject coords outside Romania (~43-48 lat, ~20-30 lng) — catches [0,0],
// Sveltia map default if user never dragged it (PN city-hall pin would mislead users),
// and lat/lng swaps.
const RO_LAT = [43.5, 48.5] as const;
const RO_LNG = [20.0, 30.0] as const;
function inRomania(lat: number, lng: number): boolean {
  return lat >= RO_LAT[0] && lat <= RO_LAT[1] && lng >= RO_LNG[0] && lng <= RO_LNG[1];
}

// Centroid lookup for known zones — built from canon SSOT.
const ZONE_CENTROIDS: Record<string, [number, number]> = Object.fromEntries(
  [...(cartierCanon.cartiere as CanonEntry[]), ...(cartierCanon.outsidePN_localitati as CanonEntry[])]
    .map(c => [c.name, c.coords] as [string, [number, number]])
);

// Serializable property data for the map script.
// Privacy: always prefer cartier centroid over exact coords (agent doesn't expose exact addresses).
function normalizeCoords(raw: unknown): [number, number] | null {
  let lat: number | null = null;
  let lng: number | null = null;
  if (Array.isArray(raw) && raw.length === 2 && typeof raw[0] === 'number' && typeof raw[1] === 'number') {
    lat = raw[0]; lng = raw[1];
  } else if (typeof raw === 'string' && raw.trim().length > 0) {
    try {
      const g = JSON.parse(raw);
      if (g && g.type === 'Point' && Array.isArray(g.coordinates) && g.coordinates.length === 2) {
        lng = Number(g.coordinates[0]);
        lat = Number(g.coordinates[1]);
      }
    } catch { /* not JSON */ }
  }
  if (lat === null || lng === null || !Number.isFinite(lat) || !Number.isFinite(lng)) return null;
  if (!inRomania(lat, lng)) return null;
  // Reject Sveltia map default = PN city center (user never dragged the marker).
  // 5m radius = ~0.00005 deg — anything closer is treated as "no exact coords".
  if (Math.abs(lat - 46.929) < 0.00005 && Math.abs(lng - 26.371) < 0.00005) return null;
  return [lat, lng];
}

// Image fallback by property type — includes Spațiu Comercial (was falling through to /sistem/teren.webp).
function pickFallbackImage(propertyType: string): string {
  if (propertyType === 'Apartament') return '/sistem/apartament.webp';
  if (propertyType === 'Casă') return '/sistem/casa.webp';
  if (propertyType === 'Spațiu Comercial') return '/sistem/comercial.webp';
  return '/sistem/teren.webp';
}

const propsForMap = visibleProperties.map((p, index) => {
  const coords = normalizeCoords(p.data.coords);
  const zoneCentroid = p.data.zone && ZONE_CENTROIDS[p.data.zone] ? ZONE_CENTROIDS[p.data.zone] : null;
  const imageSrc = p.data.featuredImage || pickFallbackImage(p.data.propertyType);
  return {
    id: p.id,
    index,
    title: p.data.title,
    image: imageSrc,
    price: p.data.price,
    currency: p.data.currency,
    coords: zoneCentroid || coords || null,
    hasExactCoords: false
  };
});
---

<Layout
  title="Proprietăți de Vânzare și Închiriere | Casa Mult Visată Piatra Neamț"
  description="Apartamente, case, terenuri și spații comerciale în Piatra Neamț. Filtrează după zonă, preț, suprafață. Comision 0%."
>

  <div class="container">
    <div class="page-header reveal">
      <p class="label">Proprietăți disponibile</p>
      <h1>Portofoliul Meu</h1>
      <p class="intro">Apartamente, case, terenuri și spații comerciale de vânzare și închiriere în Piatra Neamț și împrejurimi.</p>
    </div>

    <!-- View toggle: Listă / Hartă -->
    <div class="view-toggle" role="group" aria-label="Mod de afișare">
      <button type="button" class="view-toggle-btn active" id="view-toggle-list" data-view="list" aria-pressed="true">Listă</button>
      <button type="button" class="view-toggle-btn" id="view-toggle-map" data-view="map" aria-pressed="false">Hartă</button>
    </div>

    <!-- Search bar -->
    <div class="filter-search-bar">
      <label for="filter-search" class="sr-only">Caută</label>
      <input
        type="search"
        id="filter-search"
        placeholder="Caută după zonă, tip, dotări (ex: dumbrava, terasă, garaj)..."
        aria-label="Caută proprietăți"
        autocomplete="off"
      />
    </div>

    <!-- Price quick-presets -->
    <div class="price-presets" role="group" aria-label="Preț — presetări rapide">
      <button type="button" class="price-chip" data-pmin="" data-pmax="30000">Sub 30.000 €</button>
      <button type="button" class="price-chip" data-pmin="30000" data-pmax="80000">30 – 80k €</button>
      <button type="button" class="price-chip" data-pmin="80000" data-pmax="150000">80 – 150k €</button>
      <button type="button" class="price-chip" data-pmin="150000" data-pmax="300000">150 – 300k €</button>
      <button type="button" class="price-chip" data-pmin="300000" data-pmax="">300k €+</button>
    </div>

    <!-- Surface quick-presets -->
    <div class="surface-presets" role="group" aria-label="Suprafață — presetări rapide">
      <button type="button" class="surface-chip" data-smin="" data-smax="50">Sub 50 mp</button>
      <button type="button" class="surface-chip" data-smin="50" data-smax="100">50 – 100 mp</button>
      <button type="button" class="surface-chip" data-smin="100" data-smax="200">100 – 200 mp</button>
      <button type="button" class="surface-chip" data-smin="200" data-smax="500">200 – 500 mp</button>
      <button type="button" class="surface-chip" data-smin="500" data-smax="">500 mp+</button>
    </div>

    <!-- Filter bar (client-side JS filtering) -->
    <div class="filter-bar" role="region" aria-label="Filtre proprietăți">
      <div class="filter-field">
        <label for="filter-type" class="sr-only">Tip proprietate</label>
        <select id="filter-type" aria-label="Tip proprietate">
          <option value="all">Toate tipurile</option>
          <option value="Apartament">Apartamente</option>
          <option value="Casă">Case / Vile</option>
          <option value="Teren">Terenuri</option>
          <option value="Spațiu Comercial">Spații Comerciale</option>
        </select>
      </div>

      <div class="filter-field">
        <label for="filter-status" class="sr-only">Tip tranzacție</label>
        <select id="filter-status" aria-label="Tip tranzacție">
          <option value="all">Vânzare + Închiriere</option>
          <option value="Vânzare">De vânzare</option>
          <option value="Închiriere">De închiriat</option>
        </select>
      </div>

      <div class="filter-field">
        <label for="sort-select" class="sr-only">Sortare</label>
        <select id="sort-select" class="sort-dropdown" aria-label="Sortează rezultatele">
          <option value="default">Recente</option>
          <option value="price-asc">Preț crescător</option>
          <option value="price-desc">Preț descrescător</option>
          <option value="surface-desc">Suprafață ↓</option>
          <option value="surface-asc">Suprafață ↑</option>
          <option value="ppsqm-asc">€/mp ↑</option>
          <option value="exclusive-first">Exclusivități primele</option>
        </select>
      </div>

      <button class="filter-toggle" id="filter-toggle" aria-expanded="false" aria-controls="filter-advanced" type="button">
        <span class="filter-toggle-label">Filtre avansate</span>
        <span class="filter-toggle-count" id="filter-active-count" aria-live="polite" hidden>0</span>
      </button>

      <div id="filter-advanced" class="filter-advanced" hidden>
        <div class="filter-field">
          <label for="filter-zone" class="sr-only">Zonă / Cartier</label>
          <select id="filter-zone" aria-label="Zonă sau cartier">
            <option value="all">Toate zonele</option>
            <option value="region:PN">📍 Piatra Neamț (toată)</option>
            <option value="region:imprejurimi">🌳 Împrejurimi Piatra Neamț</option>
            {pnZones.length > 0 && (
              <optgroup label="— Cartiere Piatra Neamț —">
                {pnZones.map(z => <option value={z}>{z}</option>)}
              </optgroup>
            )}
            {impZones.length > 0 && (
              <optgroup label="— Localități împrejurimi —">
                {impZones.map(z => <option value={z}>{z}</option>)}
              </optgroup>
            )}
          </select>
        </div>

        <div class="filter-field">
          <label for="filter-rooms" class="sr-only">Număr camere</label>
          <select id="filter-rooms" aria-label="Număr camere">
            <option value="all">Orice nr. camere</option>
            <option value="1">1 cameră</option>
            <option value="2">2 camere</option>
            <option value="3">3 camere</option>
            <option value="4">4 camere</option>
            <option value="5">5+ camere</option>
          </select>
        </div>

        <div class="filter-field">
          <label for="filter-price-min" class="sr-only">Preț minim (EUR)</label>
          <input type="number" id="filter-price-min" placeholder="Preț min €" min="0" step="1000" aria-label="Preț minim în euro">
        </div>
        <div class="filter-field">
          <label for="filter-price-max" class="sr-only">Preț maxim (EUR)</label>
          <input type="number" id="filter-price-max" placeholder="Preț max €" min="0" step="1000" aria-label="Preț maxim în euro">
        </div>

        <div class="filter-field">
          <label for="filter-surface-min" class="sr-only">Suprafață minimă (mp)</label>
          <input type="number" id="filter-surface-min" placeholder="Supr. min mp" min="0" step="1" aria-label="Suprafață minimă în metri pătrați">
        </div>
        <div class="filter-field">
          <label for="filter-surface-max" class="sr-only">Suprafață maximă (mp)</label>
          <input type="number" id="filter-surface-max" placeholder="Supr. max mp" min="0" step="1" aria-label="Suprafață maximă în metri pătrați">
        </div>

        <div class="filter-field filter-check">
          <label>
            <input type="checkbox" id="filter-comision">
            <span>Doar Comision 0%</span>
          </label>
        </div>
        <div class="filter-field filter-check">
          <label>
            <input type="checkbox" id="filter-exclusive">
            <span>Doar Exclusivități</span>
          </label>
        </div>
        <div class="filter-field filter-check">
          <label>
            <input type="checkbox" id="filter-archived">
            <span>Include retrase</span>
          </label>
        </div>
      </div>

      <button type="button" class="filter-reset" id="filter-reset">Resetează filtrele</button>
    </div>

    <div class="results-info" data-total-active={totalCount} data-total-all={totalAll}>
      <span>Se afișează <strong id="results-count">{totalCount}</strong> din <strong id="results-total">{totalCount}</strong> proprietăți</span>
    </div>

    <!-- Active filter chips strip -->
    <div class="active-chips" id="active-chips" aria-label="Filtre active" hidden></div>

    <hr class="rule">

    <div class="contact-sheet" style="margin-top:2rem;" id="properties-grid">
      {visibleProperties.map((prop, index) => {
        const imageSrc = prop.data.featuredImage || pickFallbackImage(prop.data.propertyType);
        const region = isPN(prop.data.location) ? 'PN' : 'imprejurimi';
        const zoneAliases = prop.data.zone && ZONE_ALIASES[prop.data.zone] ? ZONE_ALIASES[prop.data.zone] : [];
        // Energy class as searchable token: "clasa A" / "clasa energetica B".
        const energyTokens = prop.data.energyClass ? [`clasa ${prop.data.energyClass}`, `clasa energetica ${prop.data.energyClass}`] : [];
        const intabulatTokens = prop.data.intabulat === true ? ['intabulat', 'carte funciara', 'CF'] : [];
        const searchBlobRaw = [
          prop.data.title,
          prop.data.location,
          prop.data.zone,
          prop.data.street,
          prop.data.propertyType,
          prop.data.status,
          prop.data.listingStatus,
          prop.data.compartimentare,
          prop.data.heatingType,
          prop.data.parking,
          prop.data.condition,
          prop.data.orientation,
          prop.data.buildingType,
          prop.data.structureType,
          prop.data.confortClass,
          ...(prop.data.features || []),
          ...zoneAliases,
          ...energyTokens,
          ...intabulatTokens,
        ].filter(Boolean).join(' ').toLowerCase();
        // Normalize: strip diacritics + collapse punctuation to spaces so multi-word
        // search "centru piatra" matches stored "Centru, Piatra Neamț" (comma was breaking it).
        const searchBlob = searchBlobRaw
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[,.;:()\[\]{}!?"„"'']/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();

        // Server-side hide doar Retras (no FOUC). Vândut/Închiriat rămân vizibile cu bandă.
        const initialHidden = prop.data.listingStatus === 'Retras';

        const metaDetails: string[] = [];
        if (prop.data.rooms) metaDetails.push(`${prop.data.rooms} ${prop.data.rooms === 1 ? 'cam' : 'cam'}`);
        if (prop.data.bathrooms) metaDetails.push(`${prop.data.bathrooms} ${prop.data.bathrooms === 1 ? 'baie' : 'băi'}`);
        if (prop.data.surface) metaDetails.push(`${prop.data.surface} mp`);
        if (prop.data.landSurface) {
          metaDetails.push(prop.data.propertyType === 'Teren'
            ? `${prop.data.landSurface} mp teren`
            : `+${prop.data.landSurface} mp teren`);
        }
        if (prop.data.floor) metaDetails.push(`Et. ${prop.data.floor}`);

        // Suprafață folosită pt filtru: surface (construit) sau landSurface (teren).
        // Empty string = "necunoscut" → exclus din filtru min/max (vs `0` care făcea property fără surface
        // să apară fals-pozitiv în "≤200 mp").
        const surfaceForFilter = prop.data.surface ?? prop.data.landSurface ?? '';
        const roomsForFilter = prop.data.rooms ?? 0;

        return (
          <article
            class="cs-item reveal"
            data-id={prop.id}
            data-type={prop.data.propertyType}
            data-status={prop.data.status}
            data-zone={prop.data.zone ?? ''}
            data-street={prop.data.street ?? ''}
            data-price={prop.data.price}
            data-surface={surfaceForFilter}
            data-rooms={roomsForFilter}
            data-comision={prop.data.comisionZero ? '1' : '0'}
            data-exclusive={prop.data.exclusive ? '1' : '0'}
            data-listing-status={prop.data.listingStatus || 'Activ'}
            data-region={region}
            data-search={searchBlob}
            data-index={index}
            style={initialHidden ? 'display:none' : undefined}
          >
            <div class="cs-media">
              {(prop.data.listingStatus === 'Vândut' || prop.data.listingStatus === 'Închiriat' || prop.data.listingStatus === 'Rezervat') && (
                <span class={`cs-ribbon cs-ribbon--${prop.data.listingStatus === 'Vândut' ? 'vandut' : prop.data.listingStatus === 'Închiriat' ? 'inchiriat' : 'rezervat'}`}>{prop.data.listingStatus}</span>
              )}
              <span class="cs-status-tag">De {prop.data.status.toLowerCase()}</span>
              <span class="cs-price-tag">
                {formatPrice(prop.data.price, prop.data.currency)}
                {prop.data.pricePerUnit && <small>{prop.data.pricePerUnit}</small>}
              </span>
              <a href={`/proprietati/${prop.id}`}>
                <picture>
                  <source srcset={imageSrc.replace(/\.(webp|jpe?g|png)$/i, '.avif')} type="image/avif" />
                  <source srcset={imageSrc.replace(/\.(webp|jpe?g|png)$/i, '.webp')} type="image/webp" />
                  <img src={imageSrc} alt={prop.data.title} width="800" height="600" loading="lazy" decoding="async">
                </picture>
              </a>
            </div>
            <div class="cs-caption">
              {(prop.data.exclusive || prop.data.comisionZero) && (
                <div class="prop-badges">
                  {prop.data.exclusive && <span class="badge badge-exclusiv">Exclusiv</span>}
                  {prop.data.comisionZero && <span class="badge badge-comision-zero">Comision 0%</span>}
                </div>
              )}
              <h3><a href={`/proprietati/${prop.id}`}>{prop.data.title}</a></h3>
              {(prop.data.zone || prop.data.location) && (
                <p class="cs-zone">{prop.data.zone || prop.data.location}</p>
              )}
              {metaDetails.length > 0 && (
                <p class="meta">{metaDetails.map(d => <span>{d}</span>)}</p>
              )}
            </div>
          </article>
        )
      })}
    </div>

    <!-- Map container (shown when ?view=map) -->
    <div class="map-wrap" id="map-wrap" style="display:none;" aria-label="Hartă proprietăți">
      <div id="properties-map"></div>
    </div>

    <div class="empty-state" id="empty-state" style="display:none;">
      <h3>Nicio proprietate nu corespunde filtrelor.</h3>
      <p>Încearcă să elimini un filtru:</p>
      <div class="empty-suggestions" id="empty-suggestions"></div>
      <p class="empty-fallback">Sau <a href="/contact">contactează-mă direct</a> — adesea am oferte care nu sunt încă pe site.</p>
    </div>
  </div>

  <script is:inline set:html={`window.__PROPS__ = ${JSON.stringify(propsForMap).replace(/<\/script>/gi, '<\\/script>')};window.__ZONE_CENTROIDS__ = ${JSON.stringify(ZONE_CENTROIDS).replace(/<\/script>/gi, '<\\/script>')};`}></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // ---- Map / view-toggle state ----
      // SSOT: ZONE_CENTROIDS is derived from cartier_canon.json server-side and injected
      // via __ZONE_CENTROIDS__. No more hand-maintained duplicate here.
      const ZONE_CENTROIDS = window.__ZONE_CENTROIDS__ || {};
      const grid           = document.getElementById('properties-grid');
      const emptyState     = document.getElementById('empty-state');
      const emptySuggestions = document.getElementById('empty-suggestions');
      const resultsCount   = document.getElementById('results-count');

      const searchInp     = document.getElementById('filter-search');
      const typeSel        = document.getElementById('filter-type');
      const statusSel      = document.getElementById('filter-status');
      const zoneSel        = document.getElementById('filter-zone');
      const roomsSel       = document.getElementById('filter-rooms');
      const priceMinInp    = document.getElementById('filter-price-min');
      const priceMaxInp    = document.getElementById('filter-price-max');
      const surfMinInp     = document.getElementById('filter-surface-min');
      const surfMaxInp     = document.getElementById('filter-surface-max');
      const comisionChk    = document.getElementById('filter-comision');
      const exclusiveChk   = document.getElementById('filter-exclusive');
      const archivedChk    = document.getElementById('filter-archived');
      const activeChips    = document.getElementById('active-chips');
      const mapWrap        = document.getElementById('map-wrap');
      const viewBtnList    = document.getElementById('view-toggle-list');
      const viewBtnMap     = document.getElementById('view-toggle-map');
      const sortSel        = document.getElementById('sort-select');
      const resetBtn       = document.getElementById('filter-reset');
      const filterToggle   = document.getElementById('filter-toggle');
      const filterAdvanced = document.getElementById('filter-advanced');
      const activeCount    = document.getElementById('filter-active-count');
      const priceChips     = Array.from(document.querySelectorAll('.price-chip'));
      const surfaceChips   = Array.from(document.querySelectorAll('.surface-chip'));

      const items = Array.from(document.querySelectorAll('#properties-grid .cs-item'));
      const originalOrder = items.slice();

      // View / map state — declared early so readURLToFilters can call setView()
      let currentView = 'list';
      let leafletReady = false;
      let leafletLoading = null;
      let mapInstance = null;
      let clusterGroup = null;

      // Cache option labels (so counts can be appended/refreshed without losing originals)
      const SELECT_IDS = ['filter-type', 'filter-status', 'filter-zone', 'filter-rooms'];
      SELECT_IDS.forEach(id => {
        const sel = document.getElementById(id);
        if (!sel) return;
        sel.querySelectorAll('option').forEach(opt => {
          if (!opt.dataset.label) opt.dataset.label = opt.textContent;
        });
      });

      // --- URL <-> filtre ---
      const PARAM_MAP = {
        q:           searchInp,
        type:        typeSel,
        status:      statusSel,
        zone:        zoneSel,
        rooms:       roomsSel,
        priceMin:    priceMinInp,
        priceMax:    priceMaxInp,
        surfaceMin:  surfMinInp,
        surfaceMax:  surfMaxInp,
        sort:        sortSel
      };

      function readURLToFilters() {
        const params = new URLSearchParams(window.location.search);
        for (const [key, el] of Object.entries(PARAM_MAP)) {
          if (!el) continue;
          const v = params.get(key);
          if (v !== null) el.value = v;
        }
        if (params.get('comision') === '1') comisionChk.checked = true;
        if (params.get('exclusive') === '1') exclusiveChk.checked = true;
        if (params.get('includeArchived') === '1' && archivedChk) archivedChk.checked = true;
        const viewParam = params.get('view');
        if (viewParam === 'map') setView('map', false);
        else setView('list', false);
      }

      function writeFiltersToURL() {
        const params = new URLSearchParams();
        for (const [key, el] of Object.entries(PARAM_MAP)) {
          if (!el) continue;
          const v = (el.value || '').toString().trim();
          if (v && v !== 'all' && v !== 'default') params.set(key, v);
        }
        if (comisionChk.checked)  params.set('comision', '1');
        if (exclusiveChk.checked) params.set('exclusive', '1');
        if (archivedChk && archivedChk.checked) params.set('includeArchived', '1');
        if (currentView === 'map') params.set('view', 'map');
        const qs = params.toString();
        const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
        window.history.replaceState({}, '', url);
      }

      function num(el) {
        const n = parseFloat(el.value);
        return isNaN(n) ? null : n;
      }

      // Read current filter state into a plain object.
      function readState() {
        // Same normalization as data-search blob: NFD diacritic strip + punctuation→space collapse.
        const qNorm = (searchInp.value || '').trim().toLowerCase()
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[,.;:()\[\]{}!?"„"'']/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
        return {
          q:      qNorm,
          type:   typeSel.value,
          status: statusSel.value,
          zone:   zoneSel.value,
          rooms:  roomsSel.value,
          pMin:   num(priceMinInp),
          pMax:   num(priceMaxInp),
          sMin:   num(surfMinInp),
          sMax:   num(surfMaxInp),
          onlyCom:  comisionChk.checked,
          onlyExcl: exclusiveChk.checked,
          includeArchived: !!(archivedChk && archivedChk.checked)
        };
      }

      // Predicate: does ONE item pass a given filter state?
      function passes(it, state) {
        if (state.q) {
          const blob = it.getAttribute('data-search') || '';
          // AND-match per word: split on whitespace, every term must appear somewhere in blob.
          // "centru piatra" → ["centru", "piatra"] → both must be present, in any order.
          // Cap la 8 cuvinte ca să nu degenereze performant la paste de query lung.
          const terms = state.q.split(/\s+/).filter(Boolean).slice(0, 8);
          if (terms.length === 0) { /* whitespace-only q → no filter */ }
          else if (!terms.every(t => blob.includes(t))) return false;
        }
        if (state.type !== 'all' && it.getAttribute('data-type') !== state.type) return false;
        if (state.status !== 'all' && it.getAttribute('data-status') !== state.status) return false;

        if (state.zone !== 'all') {
          if (state.zone.startsWith('region:')) {
            const want = state.zone.slice('region:'.length);
            if ((it.getAttribute('data-region') || '') !== want) return false;
          } else {
            // NFD + strip combining marks: unifies legacy `ţ` (U+0163) cu modern `ț` (U+021B),
            // și e consistent cu data-search blob (line 281) și state.q (line 492).
            const normZ = (s) => (s || '').trim().toLowerCase()
              .normalize('NFD').replace(/[̀-ͯ]/g, '');
            const itemZ = normZ(it.getAttribute('data-zone'));
            const stateZ = normZ(state.zone);
            // Prefix-match so "Bodești" matches "Bodești de Jos", "Dărmănești" matches "Dărmănești (Aleea Ulmilor)" etc.
            if (!(itemZ === stateZ || itemZ.startsWith(stateZ + ' ') || itemZ.startsWith(stateZ + '('))) return false;
          }
        }

        if (state.rooms !== 'all') {
          const dRooms = parseInt(it.getAttribute('data-rooms') || '0', 10);
          if (state.rooms === '5') { if (dRooms < 5) return false; }
          else { if (dRooms !== parseInt(state.rooms, 10)) return false; }
        }

        const dPrice   = parseFloat(it.getAttribute('data-price') || '0');
        const dSurfaceRaw = it.getAttribute('data-surface') || '';
        const dSurface = parseFloat(dSurfaceRaw);
        const surfaceKnown = !isNaN(dSurface) && dSurface > 0;
        if (state.pMin !== null && dPrice   < state.pMin) return false;
        if (state.pMax !== null && dPrice   > state.pMax) return false;
        // Suprafață necunoscută → exclus din ORICE filtru de suprafață (evită fals-pozitiv în "≤X mp").
        if (state.sMin !== null && (!surfaceKnown || dSurface < state.sMin)) return false;
        if (state.sMax !== null && (!surfaceKnown || dSurface > state.sMax)) return false;

        if (state.onlyCom  && it.getAttribute('data-comision')  !== '1') return false;
        if (state.onlyExcl && it.getAttribute('data-exclusive') !== '1') return false;

        // Hide doar Retras unless includeArchived is on (Vândut/Închiriat rămân vizibile cu bandă)
        if (!state.includeArchived) {
          const ls = it.getAttribute('data-listing-status') || 'Activ';
          if (ls === 'Retras') return false;
        }

        return true;
      }

      // Count items that pass the given state.
      function countMatching(state) {
        let n = 0;
        for (const it of items) if (passes(it, state)) n++;
        return n;
      }

      // For each option in a select, compute how many items would match if THIS option were selected (other filters unchanged).
      function updateDropdownCounts(state) {
        const fieldMap = {
          'filter-type':   'type',
          'filter-status': 'status',
          'filter-zone':   'zone',
          'filter-rooms':  'rooms'
        };
        for (const [selId, stateKey] of Object.entries(fieldMap)) {
          const sel = document.getElementById(selId);
          if (!sel) continue;
          sel.querySelectorAll('option').forEach(opt => {
            const trial = Object.assign({}, state, { [stateKey]: opt.value });
            const n = countMatching(trial);
            const base = opt.dataset.label || opt.textContent;
            opt.textContent = n > 0 ? `${base} (${n})` : `${base} (0)`;
            opt.disabled = (n === 0 && opt.value !== 'all');
          });
        }
      }

      // Smart empty-state: suggest single-filter relaxations that would yield > 0 results.
      function buildEmptySuggestions(state) {
        if (!emptySuggestions) return;
        emptySuggestions.innerHTML = '';

        const candidates = [];
        const addCandidate = (label, mutator, clearVal) => {
          const trial = Object.assign({}, state);
          mutator(trial);
          const n = countMatching(trial);
          if (n > 0) candidates.push({ label, n, apply: clearVal });
        };

        if (state.q)        addCandidate(`fără căutare „${state.q}"`,         s => s.q = '',        () => { searchInp.value = ''; });
        if (state.type   !== 'all') addCandidate(`fără tipul „${typeSel.options[typeSel.selectedIndex].dataset.label || typeSel.value}"`, s => s.type = 'all', () => { typeSel.value = 'all'; });
        if (state.status !== 'all') addCandidate(`oricare tranzacție`,         s => s.status = 'all', () => { statusSel.value = 'all'; });
        if (state.zone   !== 'all') addCandidate(`în orice zonă`,              s => s.zone = 'all',   () => { zoneSel.value = 'all'; });
        if (state.rooms  !== 'all') addCandidate(`orice nr. camere`,           s => s.rooms = 'all',  () => { roomsSel.value = 'all'; });
        if (state.pMin !== null || state.pMax !== null)
          addCandidate(`orice preț`, s => { s.pMin = null; s.pMax = null; }, () => { priceMinInp.value = ''; priceMaxInp.value = ''; clearPriceChips(); });
        if (state.sMin !== null || state.sMax !== null)
          addCandidate(`orice suprafață`, s => { s.sMin = null; s.sMax = null; }, () => { surfMinInp.value = ''; surfMaxInp.value = ''; clearSurfaceChips(); });
        if (state.onlyCom)  addCandidate(`fără „Comision 0%"`,    s => s.onlyCom = false,  () => { comisionChk.checked = false; });
        if (state.onlyExcl) addCandidate(`fără „Exclusivități"`,  s => s.onlyExcl = false, () => { exclusiveChk.checked = false; });

        candidates.sort((a, b) => b.n - a.n);
        const top = candidates.slice(0, 5);

        top.forEach(c => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'empty-suggestion-btn';
          btn.innerHTML = `<span class="es-label">${c.label}</span> <span class="es-count">+${c.n}</span>`;
          btn.addEventListener('click', () => { c.apply(); applyFilters(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
          emptySuggestions.appendChild(btn);
        });

        const resetBtnEl = document.createElement('button');
        resetBtnEl.type = 'button';
        resetBtnEl.className = 'empty-suggestion-btn empty-suggestion-reset';
        resetBtnEl.innerHTML = `<span class="es-label">Resetează tot</span> <span class="es-count">${items.length} rezultate</span>`;
        resetBtnEl.addEventListener('click', () => { doReset(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
        emptySuggestions.appendChild(resetBtnEl);
      }

      function clearPriceChips() {
        priceChips.forEach(b => b.classList.remove('active'));
      }

      function clearSurfaceChips() {
        surfaceChips.forEach(b => b.classList.remove('active'));
      }

      function syncSurfaceChipsToInputs() {
        const cmin = surfMinInp.value.trim();
        const cmax = surfMaxInp.value.trim();
        surfaceChips.forEach(b => {
          const match = (b.dataset.smin || '') === cmin && (b.dataset.smax || '') === cmax;
          b.classList.toggle('active', match);
        });
      }

      function applyFilters() {
        const state = readState();

        let visible = [];
        items.forEach(it => {
          if (passes(it, state)) {
            it.style.display = '';
            visible.push(it);
          } else {
            it.style.display = 'none';
          }
        });

        // Sort
        const sort = sortSel.value;
        let sorted = visible.slice();
        if (sort === 'price-asc') {
          sorted.sort((a, b) => parseFloat(a.dataset.price) - parseFloat(b.dataset.price));
        } else if (sort === 'price-desc') {
          sorted.sort((a, b) => parseFloat(b.dataset.price) - parseFloat(a.dataset.price));
        } else if (sort === 'surface-asc') {
          sorted.sort((a, b) => parseFloat(a.dataset.surface) - parseFloat(b.dataset.surface));
        } else if (sort === 'surface-desc') {
          sorted.sort((a, b) => parseFloat(b.dataset.surface) - parseFloat(a.dataset.surface));
        } else if (sort === 'ppsqm-asc') {
          const ppsqm = (el) => {
            const s = parseFloat(el.dataset.surface);
            const p = parseFloat(el.dataset.price);
            if (!s || s <= 0 || !p) return Infinity;
            return p / s;
          };
          sorted.sort((a, b) => ppsqm(a) - ppsqm(b));
        } else if (sort === 'exclusive-first') {
          sorted.sort((a, b) => (b.dataset.exclusive === '1' ? 1 : 0) - (a.dataset.exclusive === '1' ? 1 : 0));
        } else {
          sorted.sort((a, b) => parseInt(a.dataset.index, 10) - parseInt(b.dataset.index, 10));
        }
        sorted.forEach(el => grid.appendChild(el));

        // Counter + empty state
        resultsCount.textContent = visible.length;
        // Denominator: total proprietăți activă (default) sau toate (cu Vândut/Retras) când e bifat.
        const totalEl = document.getElementById('results-total');
        const infoEl = document.querySelector('.results-info');
        if (totalEl && infoEl) {
          const totalActive = parseInt(infoEl.getAttribute('data-total-active') || '0', 10);
          const totalAll = parseInt(infoEl.getAttribute('data-total-all') || '0', 10);
          totalEl.textContent = state.includeArchived ? totalAll : totalActive;
        }
        if (visible.length === 0) {
          grid.style.display = 'none';
          emptyState.style.display = '';
          buildEmptySuggestions(state);
        } else {
          grid.style.display = '';
          emptyState.style.display = 'none';
        }

        updateDropdownCounts(state);
        writeFiltersToURL();
        updateActiveCount();
        syncPriceChipsToInputs();
        syncSurfaceChipsToInputs();
        renderActiveChips(state);
        updateMapMarkers(state);

        // When in map view, hide grid + empty state regardless of count
        applyViewVisibility(visible.length);
      }

      function updateActiveCount() {
        let n = 0;
        if (searchInp && searchInp.value.trim()) n++;
        if (typeSel    && typeSel.value    !== 'all') n++;
        if (statusSel  && statusSel.value  !== 'all') n++;
        if (zoneSel    && zoneSel.value    !== 'all') n++;
        if (roomsSel   && roomsSel.value   !== 'all') n++;
        if (priceMinInp && priceMinInp.value.trim()) n++;
        if (priceMaxInp && priceMaxInp.value.trim()) n++;
        if (surfMinInp  && surfMinInp.value.trim())  n++;
        if (surfMaxInp  && surfMaxInp.value.trim())  n++;
        if (comisionChk  && comisionChk.checked)  n++;
        if (exclusiveChk && exclusiveChk.checked) n++;
        if (archivedChk  && archivedChk.checked)  n++;
        if (!activeCount) return;
        if (n > 0) {
          activeCount.textContent = n + ' active';
          activeCount.hidden = false;
        } else {
          activeCount.textContent = '0';
          activeCount.hidden = true;
        }
      }

      function syncPriceChipsToInputs() {
        const cmin = priceMinInp.value.trim();
        const cmax = priceMaxInp.value.trim();
        priceChips.forEach(b => {
          const match = (b.dataset.pmin || '') === cmin && (b.dataset.pmax || '') === cmax;
          b.classList.toggle('active', match);
        });
      }

      if (filterToggle && filterAdvanced) {
        filterToggle.addEventListener('click', () => {
          const expanded = filterToggle.getAttribute('aria-expanded') === 'true';
          filterToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          if (expanded) filterAdvanced.setAttribute('hidden', '');
          else          filterAdvanced.removeAttribute('hidden');
        });
      }

      // Wire-up events
      const controls = [
        searchInp, typeSel, statusSel, zoneSel, roomsSel,
        priceMinInp, priceMaxInp, surfMinInp, surfMaxInp,
        comisionChk, exclusiveChk, archivedChk, sortSel
      ];
      let debounceTimer = null;
      controls.forEach(el => {
        if (!el) return;
        const evt = (el.tagName === 'INPUT' && el.type !== 'checkbox') ? 'input' : 'change';
        el.addEventListener(evt, () => {
          if (el === searchInp) {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(applyFilters, 120);
          } else {
            applyFilters();
          }
        });
      });

      // Price preset chips
      priceChips.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('active')) {
            // toggle off
            priceMinInp.value = '';
            priceMaxInp.value = '';
          } else {
            priceMinInp.value = btn.dataset.pmin || '';
            priceMaxInp.value = btn.dataset.pmax || '';
          }
          applyFilters();
        });
      });

      // Surface preset chips
      surfaceChips.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('active')) {
            surfMinInp.value = '';
            surfMaxInp.value = '';
          } else {
            surfMinInp.value = btn.dataset.smin || '';
            surfMaxInp.value = btn.dataset.smax || '';
          }
          applyFilters();
        });
      });

      function doReset() {
        searchInp.value    = '';
        typeSel.value      = 'all';
        statusSel.value    = 'all';
        zoneSel.value      = 'all';
        roomsSel.value     = 'all';
        priceMinInp.value  = '';
        priceMaxInp.value  = '';
        surfMinInp.value   = '';
        surfMaxInp.value   = '';
        comisionChk.checked  = false;
        exclusiveChk.checked = false;
        if (archivedChk) archivedChk.checked = false;
        sortSel.value      = 'default';
        clearPriceChips();
        clearSurfaceChips();
        originalOrder.forEach(el => { el.style.display = ''; grid.appendChild(el); });
        applyFilters();
      }

      resetBtn.addEventListener('click', doReset);

      // ===== Active chips strip =====
      function renderActiveChips(state) {
        if (!activeChips) return;
        activeChips.innerHTML = '';
        const chips = [];

        const addChip = (label, onClear) => chips.push({ label, onClear });

        if (state.q) addChip(`Căutare: „${state.q}"`, () => { searchInp.value = ''; });
        if (state.type !== 'all') {
          const opt = typeSel.options[typeSel.selectedIndex];
          addChip(opt ? (opt.dataset.label || opt.textContent) : state.type, () => { typeSel.value = 'all'; });
        }
        if (state.status !== 'all') {
          const opt = statusSel.options[statusSel.selectedIndex];
          addChip(opt ? (opt.dataset.label || opt.textContent) : state.status, () => { statusSel.value = 'all'; });
        }
        if (state.zone !== 'all') {
          const opt = zoneSel.options[zoneSel.selectedIndex];
          addChip(opt ? (opt.dataset.label || opt.textContent) : state.zone, () => { zoneSel.value = 'all'; });
        }
        if (state.rooms !== 'all') {
          const opt = roomsSel.options[roomsSel.selectedIndex];
          addChip(opt ? (opt.dataset.label || opt.textContent) : `${state.rooms} cam`, () => { roomsSel.value = 'all'; });
        }
        if (state.pMin !== null || state.pMax !== null) {
          let label;
          if (state.pMin !== null && state.pMax !== null) label = `Preț ${state.pMin.toLocaleString('ro-RO')}–${state.pMax.toLocaleString('ro-RO')} €`;
          else if (state.pMin !== null) label = `Preț ≥ ${state.pMin.toLocaleString('ro-RO')} €`;
          else label = `Preț ≤ ${state.pMax.toLocaleString('ro-RO')} €`;
          addChip(label, () => { priceMinInp.value = ''; priceMaxInp.value = ''; clearPriceChips(); });
        }
        if (state.sMin !== null || state.sMax !== null) {
          let label;
          if (state.sMin !== null && state.sMax !== null) label = `Supr. ${state.sMin}–${state.sMax} mp`;
          else if (state.sMin !== null) label = `Supr. ≥ ${state.sMin} mp`;
          else label = `Supr. ≤ ${state.sMax} mp`;
          addChip(label, () => { surfMinInp.value = ''; surfMaxInp.value = ''; clearSurfaceChips(); });
        }
        if (state.onlyCom) addChip('Comision 0%', () => { comisionChk.checked = false; });
        if (state.onlyExcl) addChip('Exclusivități', () => { exclusiveChk.checked = false; });
        if (state.includeArchived) addChip('Include arhivate', () => { if (archivedChk) archivedChk.checked = false; });

        if (chips.length === 0) {
          activeChips.hidden = true;
          return;
        }
        activeChips.hidden = false;

        chips.forEach(c => {
          const el = document.createElement('button');
          el.type = 'button';
          el.className = 'active-chip';
          el.innerHTML = `<span class="active-chip-label"></span><span class="active-chip-x" aria-hidden="true">×</span>`;
          el.querySelector('.active-chip-label').textContent = c.label;
          el.setAttribute('aria-label', `Elimină filtrul ${c.label}`);
          el.addEventListener('click', () => { c.onClear(); applyFilters(); });
          activeChips.appendChild(el);
        });

        if (chips.length > 1) {
          const clearAll = document.createElement('button');
          clearAll.type = 'button';
          clearAll.className = 'active-chip active-chip-clear';
          clearAll.textContent = 'Resetează tot';
          clearAll.addEventListener('click', doReset);
          activeChips.appendChild(clearAll);
        }
      }

      // ===== View toggle (list / map) =====
      function setView(v, refresh) {
        currentView = (v === 'map') ? 'map' : 'list';
        if (viewBtnList && viewBtnMap) {
          viewBtnList.classList.toggle('active', currentView === 'list');
          viewBtnList.setAttribute('aria-pressed', currentView === 'list' ? 'true' : 'false');
          viewBtnMap.classList.toggle('active', currentView === 'map');
          viewBtnMap.setAttribute('aria-pressed', currentView === 'map' ? 'true' : 'false');
        }
        if (refresh) applyFilters();
        else applyViewVisibility(null);
        if (currentView === 'map') ensureLeaflet().then(() => updateMapMarkers(readState()));
      }

      function applyViewVisibility(visibleCount) {
        if (currentView === 'map') {
          if (grid) grid.style.display = 'none';
          if (emptyState) emptyState.style.display = 'none';
          if (mapWrap) mapWrap.style.display = '';
        } else {
          if (mapWrap) mapWrap.style.display = 'none';
          // grid + empty-state visibility already handled by applyFilters when visibleCount != null
          if (visibleCount === null) {
            // fallback: just reveal grid
            if (grid) grid.style.display = '';
          }
        }
      }

      if (viewBtnList) viewBtnList.addEventListener('click', () => { setView('list', false); writeFiltersToURL(); });
      if (viewBtnMap)  viewBtnMap.addEventListener('click',  () => { setView('map',  false); writeFiltersToURL(); });

      // ===== Leaflet loader =====
      function loadScript(src) {
        return new Promise((resolve, reject) => {
          const s = document.createElement('script');
          s.src = src; s.async = true;
          s.onload = () => resolve();
          s.onerror = () => reject(new Error('Failed to load ' + src));
          document.head.appendChild(s);
        });
      }
      function loadCSS(href) {
        return new Promise((resolve) => {
          const l = document.createElement('link');
          l.rel = 'stylesheet'; l.href = href;
          l.onload = () => resolve();
          l.onerror = () => resolve();
          document.head.appendChild(l);
        });
      }
      function ensureLeaflet() {
        if (leafletReady) return Promise.resolve();
        if (leafletLoading) return leafletLoading;
        leafletLoading = (async () => {
          await Promise.all([
            loadCSS('https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'),
            loadCSS('https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css'),
            loadCSS('https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css')
          ]);
          await loadScript('https://unpkg.com/leaflet@1.9.4/dist/leaflet.js');
          await loadScript('https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js');
          initMap();
          leafletReady = true;
        })();
        return leafletLoading;
      }

      function initMap() {
        const el = document.getElementById('properties-map');
        if (!el || mapInstance) return;
        mapInstance = L.map(el, { scrollWheelZoom: true }).setView([46.929, 26.371], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; OpenStreetMap'
        }).addTo(mapInstance);
        clusterGroup = L.markerClusterGroup();
        mapInstance.addLayer(clusterGroup);
      }

      function formatPriceJS(price, currency) {
        try {
          return new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency || 'EUR', maximumFractionDigits: 0 }).format(price);
        } catch (e) {
          return price + ' ' + (currency || 'EUR');
        }
      }

      function updateMapMarkers(state) {
        if (currentView !== 'map' || !leafletReady || !mapInstance || !clusterGroup) return;
        clusterGroup.clearLayers();
        const props = window.__PROPS__ || [];
        const visibleIdx = new Set();
        items.forEach(it => {
          if (passes(it, state)) visibleIdx.add(parseInt(it.dataset.index, 10));
        });
        const markerCoords = [];
        props.forEach(p => {
          if (!p.coords) return;
          if (!visibleIdx.has(p.index)) return;
          const [lat, lng] = p.coords;
          const m = L.marker([lat, lng]);
          const html = `
            <div class="map-popup">
              <a href="/proprietati/${p.id}/" class="map-popup-thumb">
                <img src="${p.image}" alt="" loading="lazy">
              </a>
              <div class="map-popup-body">
                <h4><a href="/proprietati/${p.id}/">${p.title}</a></h4>
                <p class="map-popup-price">${formatPriceJS(p.price, p.currency)}</p>
                <a class="map-popup-link" href="/proprietati/${p.id}/">Vezi detalii →</a>
              </div>
            </div>`;
          m.bindPopup(html, { minWidth: 220 });
          clusterGroup.addLayer(m);
          markerCoords.push([lat, lng]);
        });

        if (markerCoords.length === 1) {
          mapInstance.setView(markerCoords[0], 14);
        } else if (markerCoords.length > 1) {
          const bounds = L.latLngBounds(markerCoords);
          // If extent is very small (everything clustered), use zoom 14
          if (bounds.getNorth() - bounds.getSouth() < 0.005 && bounds.getEast() - bounds.getWest() < 0.005) {
            mapInstance.setView(bounds.getCenter(), 14);
          } else {
            mapInstance.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
          }
        } else {
          mapInstance.setView([46.929, 26.371], 12);
        }
        // Fix tile rendering when map container was just shown
        setTimeout(() => mapInstance.invalidateSize(), 60);
      }

      // Init
      readURLToFilters();
      applyFilters();
      if (currentView === 'map') ensureLeaflet().then(() => updateMapMarkers(readState()));
    });
  </script>

  <style>
    /* Filter mobile collapse */
    .filter-toggle {
      display: none; /* hidden on desktop */
      background: none;
      border: none;
      padding: 0.5rem 0;
      font-family: var(--font-accent);
      font-size: 0.875rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent);
      cursor: pointer;
      text-align: left;
    }
    .filter-toggle-count {
      display: inline-block;
      margin-left: 0.5rem;
      font-size: 0.75rem;
      color: var(--accent-green);
      font-weight: 600;
    }
    .filter-toggle::after {
      content: " ▼";
      font-size: 0.6em;
      margin-left: 0.25rem;
    }
    .filter-toggle[aria-expanded="true"]::after {
      content: " ▲";
    }

    /* Desktop: advanced container always visible, even with [hidden] attr (set for mobile-first) */
    @media (min-width: 641px) {
      .filter-advanced,
      .filter-advanced[hidden] {
        display: contents;
      }
    }

    @media (max-width: 640px) {
      .filter-toggle { display: block; }
      .filter-advanced[hidden] { display: none; }
      .filter-advanced {
        display: grid;
        gap: 0.75rem;
        margin-top: 1rem;
      }
    }

    /* === SURFACE CHIPS === */
    .surface-presets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0.75rem 0 1rem;
    }
    .surface-chip {
      font-family: var(--font-accent);
      font-size: 0.8125rem;
      font-weight: 500;
      padding: 0.45rem 0.9rem;
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--rule-color);
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .surface-chip:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
    .surface-chip.active {
      background: var(--accent);
      color: var(--surface-primary, #fff);
      border-color: var(--accent);
    }
  </style>
</Layout>
