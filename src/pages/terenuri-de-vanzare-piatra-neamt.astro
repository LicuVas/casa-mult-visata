---
// SILOZ SEO — „terenuri de vanzare piatra neamt". Aditiv; reutilizează PropertyCard
// + grila globală .contact-sheet. page-header FĂRĂ `reveal`.
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PropertyCard from '../components/PropertyCard.astro';

const all = await getCollection('proprietati');
const order = (s?: string) => (s === 'Retras' ? 99 : s === 'Vândut' || s === 'Închiriat' ? 2 : s === 'Rezervat' ? 1 : 0);
const items = all
  .filter(p => p.data.propertyType === 'Teren' && (p.data.listingStatus || 'Activ') !== 'Retras')
  .sort((a, b) => order(a.data.listingStatus) - order(b.data.listingStatus));

const origin = 'https://casamultvisata.ro';
const path = '/terenuri-de-vanzare-piatra-neamt/';
const extraSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', '@id': `${origin}${path}#page`, 'name': 'Terenuri de Vânzare în Piatra Neamț și Împrejurimi',
      'description': 'Terenuri intravilane și extravilane de vânzare în Piatra Neamț, Dumbrava Roșie, Ciriței și comunele din Neamț.',
      'url': `${origin}${path}`, 'isPartOf': { '@id': `${origin}/#website` }, 'about': { '@id': `${origin}/#agent` } },
    { '@type': 'BreadcrumbList', 'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Acasă', 'item': `${origin}/` },
      { '@type': 'ListItem', 'position': 2, 'name': 'Proprietăți', 'item': `${origin}/proprietati/` },
      { '@type': 'ListItem', 'position': 3, 'name': 'Terenuri de vânzare Piatra Neamț', 'item': `${origin}${path}` } ] },
    { '@type': 'ItemList', 'name': 'Terenuri de vânzare Piatra Neamț', 'numberOfItems': items.length,
      'itemListElement': items.map((p, i) => ({ '@type': 'ListItem', 'position': i + 1, 'url': `${origin}/proprietati/${p.id}`, 'name': p.data.title })) },
  ],
};
---
<Layout
  title="Terenuri de Vânzare în Piatra Neamț și Împrejurimi | Casa Mult Visată"
  description="Terenuri intravilane și extravilane de vânzare în Piatra Neamț, Dumbrava Roșie, Ciriței și împrejurimi. Agent Cozma Vasile, comision 0% cumpărător."
  canonicalPath={path}
  extraSchema={extraSchema}
>
  <div class="container">
    <nav class="breadcrumb" aria-label="Firimituri">
      <a href="/">Acasă</a> › <a href="/proprietati">Proprietăți</a> › <span>Terenuri de vânzare</span>
    </nav>
    <div class="page-header">
      <p class="label">Terenuri</p>
      <h1>Terenuri de Vânzare în Piatra Neamț și Împrejurimi</h1>
      <p class="intro">Loturi intravilane pentru casă și terenuri mai mari în Piatra Neamț, Dumbrava Roșie, Ciriței și comunele din jur. Pentru fiecare teren îți spun clar ce se poate construi, ce utilități sunt în zonă și cum stă cu actele.</p>
    </div>

    {items.length > 0 ? (
      <div class="contact-sheet" style="margin-top:1.5rem;">
        {items.map(prop => <PropertyCard prop={prop} />)}
      </div>
    ) : (
      <p class="intro">Momentan nu am un teren listat public. <a href="/contact">Spune-mi ce cauți</a> (zonă, suprafață, intravilan/extravilan, buget) și caut pentru tine.</p>
    )}

    <section class="silo-copy">
      <h2>Ce contează la cumpărarea unui teren</h2>
      <p>Un teren bun nu înseamnă doar preț pe metru pătrat. Contează dacă e intravilan sau extravilan, ce permite certificatul de urbanism (regim de înălțime, retrageri), dacă are acces la drum și utilități — curent, apă, gaz, canalizare — și, esențial, situația cadastrală: intabulare, carte funciară, fără litigii. Verific aceste aspecte înainte, ca să nu cumperi o problemă.</p>
      <h2>Zonele cu terenuri disponibile</h2>
      <p>Cele mai multe loturi sunt în Dumbrava Roșie, zona Fermelor și Ciriței — căutate pentru construcția de case — plus terenuri mai mari în comunele din județul Neamț, la prețuri mai accesibile. Dacă vrei o zonă anume sau o anumită suprafață, spune-mi și caut punctual.</p>
      <p class="silo-cta">Cauți și case sau apartamente? Vezi <a href="/proprietati">tot portofoliul</a> sau <a href="/contact">scrie-mi direct</a>. Pentru cumpărători, comisionul este <strong>0%</strong>.</p>
    </section>
  </div>
</Layout>

<style>
  .breadcrumb { font-size: 0.85rem; color: var(--muted, #667); margin: 1.5rem 0 0.5rem; }
  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .silo-copy { max-width: 760px; margin: 3.5rem 0 1rem; }
  .silo-copy h2 { margin-top: 1.75rem; }
  .silo-copy p { line-height: 1.7; }
  .silo-cta { margin-top: 1.75rem; }
</style>
