    <script type="application/ld+json" set:html={JSON.stringify(realEstateListing)} />

    {prop.data.price && prop.data.rooms && (
        <script is:inline define:vars={{ price: prop.data.price, currency: prop.data.currency }}>
            document.addEventListener('DOMContentLoaded', function () {
                var elDown = document.getElementById('mc-down');
                var elYears = document.getElementById('mc-years');
                var elRate = document.getElementById('mc-rate');
                var elDownPct = document.getElementById('mc-down-pct');
                var elYearsVal = document.getElementById('mc-years-val');
                var elRateVal = document.getElementById('mc-rate-val');
                var elMonthly = document.getElementById('mc-monthly');
                var elLoan = document.getElementById('mc-loan');
                var elTotalInterest = document.getElementById('mc-total-interest');
                if (!elDown || !elYears || !elRate || !elMonthly) return;

                var fmt = new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency, maximumFractionDigits: 0 });

                function calc() {
                    var downPct = parseFloat(elDown.value);
                    var years = parseInt(elYears.value, 10);
                    var ratePct = parseFloat(elRate.value);

                    if (elDownPct) elDownPct.textContent = downPct;
                    if (elYearsVal) elYearsVal.textContent = years;
                    if (elRateVal) elRateVal.textContent = ratePct.toFixed(1);

                    var loan = price * (1 - downPct / 100);
                    var n = years * 12;
                    var r = (ratePct / 100) / 12;

                    var monthly;
                    if (r === 0) {
                        monthly = loan / n;
                    } else {
                        var pow = Math.pow(1 + r, n);
                        monthly = loan * r * pow / (pow - 1);
                    }
                    var totalPaid = monthly * n;
                    var totalInterest = totalPaid - loan;

                    elMonthly.textContent = fmt.format(Math.round(monthly));
                    if (elLoan) elLoan.textContent = fmt.format(Math.round(loan));
                    if (elTotalInterest) elTotalInterest.textContent = fmt.format(Math.round(totalInterest));
                }

                ['input', 'change'].forEach(function (ev) {
                    elDown.addEventListener(ev, calc);
                    elYears.addEventListener(ev, calc);
                    elRate.addEventListener(ev, calc);
                });
                calc();
            });
        </script>
    )}

    {images.length >= 1 && (
        <script type="module">
            import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5.4.4/dist/photoswipe-lightbox.esm.js';
            const lightbox = new PhotoSwipeLightbox({
                gallery: '#pswp-gallery',
                children: 'a',
                pswpModule: () => import('https://unpkg.com/photoswipe@5.4.4/dist/photoswipe.esm.js'),
                bgOpacity: 0.95,
                showHideAnimationType: 'fade',
                counter: true,
                zoom: true,
                pinchToClose: true,
                closeOnVerticalDrag: true,
            });
            lightbox.init();
            window.__pswpLightbox = lightbox;

            document.addEventListener('DOMContentLoaded', function () {
                const hero = document.getElementById('hero-image');
                const heroHint = document.querySelector('.hero-zoom-hint');
                const galleryAnchors = document.querySelectorAll('#pswp-gallery a');

                function openFirst(e) {
                    if (e) e.preventDefault();
                    if (galleryAnchors.length > 0) {
                        galleryAnchors[0].click();
                    } else if (window.__pswpLightbox && window.__pswpLightbox.loadAndOpen) {
                        window.__pswpLightbox.loadAndOpen(0);
                    }
                }
                if (hero) {
                    hero.style.cursor = 'zoom-in';
                    hero.addEventListener('click', openFirst);
                }
                if (heroHint) heroHint.addEventListener('click', openFirst);
            });
        </script>
    )}

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            var copyBtn = document.getElementById('share-copy-btn');
            var copyLbl = document.getElementById('share-copy-label');
            if (copyBtn && copyLbl) {
                copyBtn.addEventListener('click', function () {
                    var url = window.location.href;
                    var done = function () {
                        var orig = 'Copiază link';
                        copyLbl.textContent = 'Link copiat!';
                        copyBtn.classList.add('is-copied');
                        setTimeout(function () {
                            copyLbl.textContent = orig;
                            copyBtn.classList.remove('is-copied');
                        }, 1800);
                    };
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(url).then(done, function () {
                            try {
                                var ta = document.createElement('textarea');
                                ta.value = url; document.body.appendChild(ta);
                                ta.select(); document.execCommand('copy');
                                document.body.removeChild(ta); done();
                            } catch (e) {}
                        });
                    } else {
                        try {
                            var ta2 = document.createElement('textarea');
                            ta2.value = url; document.body.appendChild(ta2);
                            ta2.select(); document.execCommand('copy');
                            document.body.removeChild(ta2); done();
                        } catch (e) {}
                    }
                });
            }

            // Wire up detail-page favorite button to global CMV_FAV API
            var favBtn = document.getElementById('detail-fav-btn');
            if (favBtn && window.CMV_FAV) {
                var id = favBtn.getAttribute('data-fav-id');
                var lblSpan = favBtn.querySelector('.fav-toggle-label');
                function syncState() {
                    var active = window.CMV_FAV.has(id);
                    favBtn.classList.toggle('is-active', active);
                    favBtn.setAttribute('aria-pressed', active ? 'true' : 'false');
                    favBtn.setAttribute('aria-label', active ? 'Elimină de la favorite' : 'Salvează la favorite');
                    favBtn.setAttribute('title', active ? 'Elimină de la favorite' : 'Salvează la favorite');
                    if (lblSpan) lblSpan.textContent = active ? 'Salvat' : 'Favorit';
                    var svg = favBtn.querySelector('svg');
                    if (svg) svg.setAttribute('fill', active ? 'currentColor' : 'none');
                }
                favBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    window.CMV_FAV.toggle(id);
                    syncState();
                });
                document.addEventListener('favorites-changed', syncState);
                syncState();
            }
        });
    </script>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            // Sidebar "Distribuie" — native share sheet, fallback to clipboard.
            var shareBtn = document.getElementById('detail-share-btn');
            if (shareBtn) {
                shareBtn.addEventListener('click', function () {
                    var url = window.location.href;
                    var title = document.title;
                    if (navigator.share) {
                        navigator.share({ title: title, url: url }).catch(function () {});
                    } else if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(url).then(function () {
                            var lbl = shareBtn.querySelector('span');
                            if (lbl) { var o = lbl.textContent; lbl.textContent = 'Copiat!'; setTimeout(function () { lbl.textContent = o; }, 1600); }
                        }, function () {});
                    }
                });
            }
            // Sidebar "Printare"
            var printBtn = document.getElementById('detail-print-btn');
            if (printBtn) printBtn.addEventListener('click', function () { window.print(); });
        });
    </script>

    <script is:inline>
        (function () {
            var mapEl = document.getElementById('leaflet-map');
            if (!mapEl) return;
            var lat = parseFloat(mapEl.dataset.lat);
            var lng = parseFloat(mapEl.dataset.lng);
            var zoom = parseInt(mapEl.dataset.zoom, 10) || 14;
            var title = mapEl.dataset.title || '';
            var approximate = mapEl.dataset.approximate === '1';
            if (isNaN(lat) || isNaN(lng)) return;

            function initMap() {
                if (!window.L) return;
                var map = L.map(mapEl, { scrollWheelZoom: false }).setView([lat, lng], zoom);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);
                if (approximate) {
                    // Zonă aproximativă: cerc translucid în loc de pin
                    L.circle([lat, lng], {
                        radius: 350,
                        color: '#8AA399',
                        weight: 2,
                        fillColor: '#8AA399',
                        fillOpacity: 0.18
                    }).addTo(map).bindPopup('Zonă aproximativă: ' + title);
                } else {
                    L.marker([lat, lng]).addTo(map).bindPopup(title);
                }
            }

            if (window.L) {
                initMap();
            } else {
                var s = document.createElement('script');
                s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
                s.crossOrigin = '';
                s.onload = initMap;
                document.head.appendChild(s);
            }
        })();
    </script>

    <style>
        #pswp-gallery a { display: block; line-height: 0; text-decoration: none; }
        #pswp-gallery a img { display: block; width: 100%; height: auto; }
        .pswp { --pswp-bg: #1a1a1a; }
        .pswp__counter { font-family: var(--font-accent); }

        /* Sticky CTA bar — only on mobile/small screens, conversion-lift pattern (2025 best practice). */
        .sticky-cta-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            display: none;
            grid-template-columns: 1fr auto;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem calc(0.5rem + env(safe-area-inset-bottom, 0)) 0.75rem;
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-top: 1px solid var(--border-light, #e5e5e5);
            box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.06);
            z-index: 50;
            align-items: center;
        }
        @media (max-width: 900px) {
            .sticky-cta-bar { display: grid; }
            .container.property-detail { padding-bottom: 5rem !important; }
        }
        .sticky-cta-bar .sticky-price {
            display: flex;
            flex-direction: column;
            line-height: 1.15;
            min-width: 0;
        }
        .sticky-cta-bar .sticky-price strong {
            font-family: var(--font-display);
            font-size: 1.125rem;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .sticky-cta-bar .sticky-price small {
            font-family: var(--font-body);
            font-size: 0.75rem;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 60vw;
        }
        .sticky-cta-bar .sticky-actions {
            display: flex;
            gap: 0.375rem;
        }
        .sticky-cta-bar .sticky-actions a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            text-decoration: none;
        }
        .sticky-cta-bar .sticky-actions .cta-call { background: var(--accent, #5f7a4e); color: #fff; }
        .sticky-cta-bar .sticky-actions .cta-wa { background: #25D366; color: #fff; }
        .sticky-cta-bar .sticky-actions .cta-msg { background: var(--surface-secondary, #f3f1ec); color: var(--text-primary); border: 1px solid var(--border-light, #e5e5e5); }

        /* Energy class badges — color-coded per UE standard */
        .energy-badge {
            display: inline-block;
            padding: 0.125rem 0.5rem;
            border-radius: 4px;
            font-weight: 600;
            color: #fff;
            font-size: 0.875rem;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .energy-A { background: #009933; }
        .energy-B { background: #4caf50; }
        .energy-C { background: #cddc39; color: #2b2b2b; }
        .energy-D { background: #ffeb3b; color: #2b2b2b; }
        .energy-E { background: #ffc107; color: #2b2b2b; }
        .energy-F { background: #ff9800; }
        .energy-G { background: #f44336; }
        .energy-pending { background: var(--surface-secondary, #f3f1ec); color: var(--text-secondary); border: 1px dashed #999; }

        /* ===== Clickable taxonomy tags ===== */
        .prop-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 1rem; }
        .prop-tag {
            font-family: var(--font-accent); font-size: 0.8125rem; font-weight: 500;
            letter-spacing: 0.02em; text-decoration: none;
            color: var(--accent-green); background: var(--accent-light, #e7eee9);
            padding: 0.3rem 0.85rem; border-radius: 999px; transition: background 0.18s, color 0.18s;
        }
        .prop-tag:hover { background: var(--accent-green); color: #fff; }

        /* ===== Clickable location line ===== */
        .prop-location {
            display: flex; align-items: center; flex-wrap: wrap; gap: 0.15rem;
            font-family: var(--font-accent); font-size: 1.05rem; color: var(--text-secondary);
            margin-bottom: 1.5rem;
        }
        .prop-location svg { color: var(--accent-green); margin-right: 0.35rem; flex-shrink: 0; }
        .prop-location a { color: var(--text-secondary); text-decoration: none; border-bottom: 1px solid transparent; transition: color 0.18s, border-color 0.18s; }
        .prop-location a:hover { color: var(--accent-green); border-bottom-color: var(--accent-green); }

        /* ===== Content cards (Detalii / Facilități) ===== */
        .detail-card {
            background: var(--white, #fff); border: 1px solid var(--rule-color, #e7e2d8);
            border-radius: 14px; padding: 2rem; margin-top: 2.5rem;
            box-shadow: 0 8px 26px rgba(20, 30, 50, 0.05);
        }
        .detail-card .section-heading { margin-top: 0; margin-bottom: 1.5rem; }

        .detalii-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem 2.5rem; margin: 0; }
        .detalii-row { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; padding-bottom: 0.6rem; border-bottom: 1px solid var(--rule-color, #efeae0); }
        .detalii-row dt { font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); margin: 0; }
        .detalii-row dd { font-family: var(--font-body); font-weight: 600; color: var(--text-primary); margin: 0; text-align: right; }

        .facilitati-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.85rem 1.5rem; }
        .facilitati-item { display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-primary); }
        .facilitati-item svg { color: var(--accent-green); flex-shrink: 0; }

        /* ===== Price above the map ===== */
        .map-price-row { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
        .map-price { font-family: var(--font-display); font-size: 1.6rem; font-weight: 400; color: var(--accent-green); }

        /* ===== Inquiry listing code ===== */
        .inquiry-code { font-family: var(--font-accent); font-size: 0.85rem; color: var(--text-secondary); margin: -0.5rem 0 1.25rem; }
        .inquiry-code strong { color: var(--accent-green); letter-spacing: 0.03em; }

        /* ===== Sidebar buy box (dellarte-inspired) ===== */
        .detail-buy-box {
            background: var(--surface-secondary); border-radius: 14px; padding: 1.75rem;
            margin-bottom: 1.25rem;
        }
        .buy-price { display: flex; flex-direction: column; gap: 0.15rem; margin-bottom: 1.25rem; }
        .buy-price-label { font-family: var(--font-accent); font-variant: small-caps; text-transform: lowercase; letter-spacing: var(--letter-spacing-caps); font-size: 0.8rem; color: var(--text-secondary); }
        .buy-price-amount { font-family: var(--font-display); font-size: 2.25rem; font-weight: 400; line-height: 1.05; color: var(--accent-green); }
        .buy-price-unit { font-family: var(--font-body); font-size: 0.95rem; color: var(--text-secondary); }
        .buy-price-com { font-family: var(--font-accent); font-size: 0.8rem; font-weight: 600; color: var(--accent-green); margin-top: 0.25rem; }

        .buy-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-bottom: 1.25rem; }
        .buy-action {
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.3rem;
            background: var(--white, #fff); border: 1px solid var(--rule-color, #e7e2d8); border-radius: 10px;
            padding: 0.7rem 0.4rem; cursor: pointer; color: var(--text-primary);
            font-family: var(--font-accent); font-size: 0.78rem; font-weight: 500;
            transition: border-color 0.18s, color 0.18s, background 0.18s;
        }
        .buy-action svg { color: var(--accent-green); }
        .buy-action:hover { border-color: var(--accent-green); color: var(--accent-green); }
        .buy-action.fav-toggle.is-active { border-color: var(--accent-green); color: var(--accent-green); }
        .buy-action.fav-toggle.is-active svg { fill: var(--accent-green); }

        .buy-agent-card { display: block; text-decoration: none; margin-bottom: 1.5rem; text-align: center; }
        .buy-agent-card picture { display: block; border-radius: 10px; overflow: hidden; line-height: 0; }
        .buy-agent-card img { width: 100%; height: auto; display: block; aspect-ratio: 1 / 1; object-fit: cover; object-position: center top; transition: transform 0.3s ease; }
        .buy-agent-card:hover img { transform: scale(1.03); }
        .buy-agent-name { display: block; font-family: var(--font-display); font-size: 1.1rem; color: var(--text-primary); margin-top: 0.65rem; }
        .buy-agent-role { display: block; font-family: var(--font-accent); font-size: 0.8rem; color: var(--accent-green); margin-top: 0.1rem; }

        .buy-cta { display: flex; flex-direction: column; gap: 1rem; }

        @media (max-width: 700px) {
            .detalii-grid { grid-template-columns: 1fr; gap: 0.5rem 0; }
            .detail-card { padding: 1.5rem; }
        }
    </style>

