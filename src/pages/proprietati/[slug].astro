---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import imageDims from '../../data/image_dims.json';
import cartierCanon from '../../../tools/cartier_canon.json';
import { listingId } from '../../utils/listingId';
import { cdnImg, cdnSrcset } from '../../lib/img';
import { displayZone, parseLocalitate } from '../../utils/localitate';

const DIMS = imageDims as Record<string, [number, number]>;
function getDims(src: string): [number, number] {
  return DIMS[src] || [1200, 900];
}

// Normalize coords from either legacy [lat,lng] tuple OR Sveltia GeoJSON string Point.
// GeoJSON Point coordinates are [lng, lat] (longitude first).
// Hardening: Romania bbox guard + reject Sveltia default (PN city-center = user never dragged).
function normalizeCoords(raw: unknown): [number, number] | null {
  let lat: number | null = null;
  let lng: number | null = null;
  if (Array.isArray(raw) && raw.length === 2 && typeof raw[0] === 'number' && typeof raw[1] === 'number') {
    lat = raw[0]; lng = raw[1];
  } else if (typeof raw === 'string' && raw.trim().length > 0) {
    try {
      const g = JSON.parse(raw);
      if (g && g.type === 'Point' && Array.isArray(g.coordinates) && g.coordinates.length === 2) {
        lng = Number(g.coordinates[0]);
        lat = Number(g.coordinates[1]);
      }
    } catch { /* not JSON */ }
  }
  if (lat === null || lng === null || !Number.isFinite(lat) || !Number.isFinite(lng)) return null;
  // Romania bbox: lat 43.5–48.5, lng 20–30. Rejects [0,0], lat/lng swaps, anything off-map.
  if (lat < 43.5 || lat > 48.5 || lng < 20.0 || lng > 30.0) return null;
  // Reject Sveltia map default = PN city center exactly (user never dragged the marker).
  if (Math.abs(lat - 46.929) < 0.00005 && Math.abs(lng - 26.371) < 0.00005) return null;
  return [lat, lng];
}

// Image fallback by property type — includes Spațiu Comercial.
function pickFallbackImage(propertyType: string): string {
  if (propertyType === 'Apartament') return '/sistem/apartament.webp';
  if (propertyType === 'Casă') return '/sistem/casa.webp';
  if (propertyType === 'Spațiu Comercial') return '/sistem/comercial.webp';
  return '/sistem/teren.webp';
}

export async function getStaticPaths() {
  const allProps = await getCollection('proprietati');
  return allProps.map(prop => ({
    params: { slug: prop.id },
    props: { prop },
  }));
}

const { prop } = Astro.props;
const { Content } = await render(prop);

// Format price
const formatPrice = (price: number, currency: string) => {
  return new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(price);
};

const fallbackImage = pickFallbackImage(prop.data.propertyType);
const imageSrc = prop.data.featuredImage || fallbackImage;

// Build gallery images: featured + gallery, dedupe, filter empty
const galleryRaw = [prop.data.featuredImage, ...(prop.data.gallery || [])].filter((v): v is string => typeof v === 'string' && v.trim().length > 0);
const images = Array.from(new Set(galleryRaw));

// Contact strings
const contactPhone = "0747814263";
const displayPhone = "0747 814 263";
const whatsappMsg = `Bună ziua! Vreau informații despre proprietatea: ${prop.data.title}`;

// SEO / OG
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://casamultvisata.ro';
const absoluteOgImage = imageSrc.startsWith('http') ? imageSrc : `${siteOrigin}${imageSrc.startsWith('/') ? imageSrc : '/' + imageSrc}`;
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;

// Description: first 160 chars from body or fallback
const rawBody = (prop.body || '').replace(/[#*_>`\-\[\]\(\)!]/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = rawBody.length > 0
  ? rawBody.slice(0, 160)
  : `${prop.data.propertyType} de ${prop.data.status.toLowerCase()} în ${prop.data.location}.`;
const jsonLdDescription = rawBody.length > 0 ? rawBody.slice(0, 200) : metaDescription;

// JSON-LD RealEstateListing
const listingStatusForLd = prop.data.listingStatus || 'Activ';
const availabilityUrl = (listingStatusForLd === 'Vândut' || listingStatusForLd === 'Închiriat')
  ? 'https://schema.org/SoldOut'
  : (listingStatusForLd === 'Rezervat' ? 'https://schema.org/Reserved' : 'https://schema.org/InStock');

// datePosted: updatedAt (ISO YYYY-MM-DD) if set, else today
const todayIso = new Date().toISOString().slice(0, 10);
const datePostedLd = (prop.data.updatedAt && /^\d{4}-\d{2}-\d{2}/.test(prop.data.updatedAt))
  ? prop.data.updatedAt.slice(0, 10)
  : todayIso;

const realEstateListing: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": prop.data.title,
  "description": jsonLdDescription,
  "url": canonicalUrl,
  "image": absoluteOgImage,
  "datePosted": datePostedLd,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": prop.data.location,
    "addressRegion": "Neamț",
    "addressCountry": "RO"
  },
  "offers": {
    "@type": "Offer",
    "price": prop.data.price,
    "priceCurrency": prop.data.currency,
    "availability": availabilityUrl,
    "url": canonicalUrl
  }
};
const normalizedCoords = normalizeCoords(prop.data.coords);
if (normalizedCoords) {
  realEstateListing.geo = {
    "@type": "GeoCoordinates",
    "latitude": normalizedCoords[0],
    "longitude": normalizedCoords[1]
  };
}
if (prop.data.surface) {
  realEstateListing.floorSize = { "@type": "QuantitativeValue", "value": prop.data.surface, "unitCode": "MTK" };
}
if (prop.data.rooms) {
  realEstateListing.numberOfRooms = prop.data.rooms;
  // numberOfBedrooms = rooms - 1 pentru apartamente standard RO (sufrageria nu se numără).
  // Pentru garsonieră (rooms=1) → 0 dormitoare separate, deci omitem field-ul.
  if ((prop.data.propertyType === 'Apartament' || prop.data.propertyType === 'Casă') && prop.data.rooms >= 2) {
    realEstateListing.numberOfBedrooms = prop.data.rooms - 1;
  }
}
if (prop.data.bathrooms) realEstateListing.numberOfBathroomsTotal = prop.data.bathrooms;
if (prop.data.yearBuilt) realEstateListing.yearBuilt = prop.data.yearBuilt;
if (prop.data.floorsTotal) realEstateListing.numberOfFloors = prop.data.floorsTotal;
realEstateListing.mainEntityOfPage = canonicalUrl;
// dateModified din updatedAt dacă există
if (prop.data.updatedAt && /^\d{4}-\d{2}-\d{2}/.test(prop.data.updatedAt)) {
  realEstateListing.dateModified = prop.data.updatedAt.slice(0, 10);
}
// Offer enrichment: businessFunction (Sell vs LeaseOut) + seller
realEstateListing.offers.businessFunction = prop.data.status === 'Închiriere'
  ? 'https://schema.org/LeaseOut'
  : 'https://schema.org/Sell';
realEstateListing.offers.seller = { "@type": "RealEstateAgent", "name": "Cozma Vasile", "url": siteOrigin };
// amenityFeature din features array. Pentru free-text features (RO real-estate),
// omit `value: true` — Schema.org bool e pentru booleane proprii (ex: petsAllowed),
// nu pentru caracteristici descriptive ("Terasă acoperită", "Mobilat").
if (prop.data.features && prop.data.features.length > 0) {
  realEstateListing.amenityFeature = prop.data.features.map(f => ({
    "@type": "LocationFeatureSpecification",
    "name": f
  }));
}
// additionalProperty pentru câmpuri RO-specifice care nu au mapping direct în Schema.org
const additionalProps: any[] = [];
if (prop.data.energyClass) additionalProps.push({ "@type": "PropertyValue", "name": "Clasă energetică", "value": prop.data.energyClass });
if (prop.data.compartimentare) additionalProps.push({ "@type": "PropertyValue", "name": "Compartimentare", "value": prop.data.compartimentare });
if (prop.data.heatingType) additionalProps.push({ "@type": "PropertyValue", "name": "Tip încălzire", "value": prop.data.heatingType });
if (prop.data.parking) additionalProps.push({ "@type": "PropertyValue", "name": "Parcare", "value": prop.data.parking });
if (prop.data.orientation) additionalProps.push({ "@type": "PropertyValue", "name": "Orientare", "value": prop.data.orientation });
if (prop.data.condition) additionalProps.push({ "@type": "PropertyValue", "name": "Stare", "value": prop.data.condition });
if (prop.data.intabulat === true) additionalProps.push({ "@type": "PropertyValue", "name": "Intabulat", "value": "Da" });
if (prop.data.floor) additionalProps.push({ "@type": "PropertyValue", "name": "Etaj", "value": prop.data.floor });
if (prop.data.balconies) additionalProps.push({ "@type": "PropertyValue", "name": "Balcoane", "value": prop.data.balconies });
if (additionalProps.length > 0) realEstateListing.additionalProperty = additionalProps;

const contactHref = `/contact/?proprietate=${encodeURIComponent(prop.data.title)}`;

// === DETAIL ENRICH ===
const listingStatus = prop.data.listingStatus || 'Activ';
const isFaded = listingStatus === 'Vândut' || listingStatus === 'Închiriat' || listingStatus === 'Retras';

// Romanian-formatted updatedAt
const RO_MONTHS = ['ianuarie','februarie','martie','aprilie','mai','iunie','iulie','august','septembrie','octombrie','noiembrie','decembrie'];
let updatedAtFormatted: string | null = null;
if (prop.data.updatedAt) {
  const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(prop.data.updatedAt);
  if (m) {
    const y = parseInt(m[1], 10);
    const mo = parseInt(m[2], 10);
    const d = parseInt(m[3], 10);
    if (mo >= 1 && mo <= 12) updatedAtFormatted = `${d} ${RO_MONTHS[mo - 1]} ${y}`;
  }
}

// Map coordinates — SSOT derived from tools/cartier_canon.json.
type CanonEntry = { name: string; coords: [number, number] };
const ZONE_CENTROIDS_SERVER: Record<string, [number, number]> = Object.fromEntries(
  [...(cartierCanon.cartiere as CanonEntry[]), ...(cartierCanon.outsidePN_localitati as CanonEntry[])]
    .map(c => [c.name, c.coords] as [string, [number, number]])
);
let mapLat: number;
let mapLng: number;
let mapZoom: number;
let mapApproximate: boolean;
// Privacy policy: ALL property locations rendered as approximate circles, never precise pins.
// (Real-estate agents don't publish exact addresses online.)
if (normalizedCoords) {
  mapLat = normalizedCoords[0];
  mapLng = normalizedCoords[1];
  mapZoom = 15;
} else if ((prop.data.zone || parseLocalitate(prop.data.localitate)?.sat) && ZONE_CENTROIDS_SERVER[prop.data.zone || parseLocalitate(prop.data.localitate)?.sat || '']) {
  const zk = prop.data.zone || parseLocalitate(prop.data.localitate)?.sat || '';
  mapLat = ZONE_CENTROIDS_SERVER[zk][0];
  mapLng = ZONE_CENTROIDS_SERVER[zk][1];
  mapZoom = 14;
} else {
  mapLat = 46.929;
  mapLng = 26.371;
  mapZoom = 13;
}
mapApproximate = true; // Always approximate — circle, not pin

// Similar properties: pick 3
const allForSimilar = await getCollection('proprietati');
const eligibleForSimilar = allForSimilar.filter(p => {
  if (p.id === prop.id) return false;
  const st = p.data.listingStatus || 'Activ';
  if (st === 'Vândut' || st === 'Retras') return false;
  return true;
});
const sameType = eligibleForSimilar.filter(p => p.data.propertyType === prop.data.propertyType);
let similar = sameType.slice(0, 3);
if (similar.length < 3) {
  const sameZone = eligibleForSimilar.filter(p =>
    p.data.zone && prop.data.zone && p.data.zone === prop.data.zone &&
    !similar.find(s => s.id === p.id)
  );
  for (const cand of sameZone) {
    if (similar.length >= 3) break;
    similar.push(cand);
  }
}
similar = similar.slice(0, 3);

const isPNloc = (loc?: string): boolean => !!loc && /Piatra Neam/i.test(loc);

// Share URLs
const shareUrl = canonicalUrl;
const shareText = `Uite ce am găsit: ${prop.data.title} — ${shareUrl}`;
const waShareHref = `https://wa.me/?text=${encodeURIComponent(shareText)}`;
const fbShareHref = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;

// Inquiry default message
const inquiryDefaultMsg = `Bună ziua! Sunt interesat(ă) de proprietatea ${prop.data.title}. Vă rog să mă contactați.`;

const hasTour = !!prop.data.videoUrl || !!prop.data.virtualTourUrl;

// === Public listing code (stable, derived from slug) ===
const lid = listingId(prop.id);

// === Clickable taxonomy + location → filtered listing pages ===
// Param names match the filter logic in /proprietati (type, status, zone, q).
const statusHref = `/proprietati/?status=${encodeURIComponent(prop.data.status)}`;
const typeHref = `/proprietati/?type=${encodeURIComponent(prop.data.propertyType)}`;
// Zona efectivă: clasică sau frunza din `localitate` (sat/cartier), pt anunțuri noi structurate.
const effZone = prop.data.zone || (parseLocalitate(prop.data.localitate)?.sat ?? '');
const zoneHref = effZone ? `/proprietati/?zone=${encodeURIComponent(effZone)}` : null;
const locHref = `/proprietati/?q=${encodeURIComponent(prop.data.location)}`;
const streetHref = prop.data.street ? `/proprietati/?q=${encodeURIComponent(prop.data.street)}` : null;

// === "Detalii imobiliare" rows (moved into main content, dellarte-style) ===
const surfUtila = prop.data.surfaceUtila ?? prop.data.surface;
const detalii: { label: string; value: string }[] = [];
detalii.push({ label: 'ID anunț', value: lid });
detalii.push({ label: 'Preț', value: formatPrice(prop.data.price, prop.data.currency) });
detalii.push({ label: 'Tip', value: prop.data.propertyType });
if (surfUtila) detalii.push({ label: 'Suprafață utilă', value: `${surfUtila} mp` });
if (prop.data.surfaceConstruita) detalii.push({ label: 'Suprafață construită', value: `${prop.data.surfaceConstruita} mp` });
if (prop.data.landSurface) detalii.push({ label: 'Suprafață teren', value: `${prop.data.landSurface} mp` });
if (prop.data.rooms) detalii.push({ label: 'Camere', value: String(prop.data.rooms) });
if (prop.data.bathrooms) detalii.push({ label: 'Băi', value: String(prop.data.bathrooms) });
if (prop.data.floor) detalii.push({ label: 'Etaj', value: prop.data.floor });
if (prop.data.floorsTotal) detalii.push({ label: 'Etaje clădire', value: String(prop.data.floorsTotal) });
if (prop.data.compartimentare) detalii.push({ label: 'Compartimentare', value: prop.data.compartimentare });
if (prop.data.yearBuilt) detalii.push({ label: 'An construcție', value: String(prop.data.yearBuilt) });
if (prop.data.heatingType) detalii.push({ label: 'Încălzire', value: prop.data.heatingType });
if (prop.data.energyClass) detalii.push({ label: 'Clasă energetică', value: prop.data.energyClass });
if (prop.data.parking) detalii.push({ label: 'Parcare', value: prop.data.parking });
if (prop.data.orientation) detalii.push({ label: 'Orientare', value: prop.data.orientation });
if (prop.data.condition) detalii.push({ label: 'Stare', value: prop.data.condition });
if (prop.data.buildingType) detalii.push({ label: 'Tip clădire', value: prop.data.buildingType });
if (prop.data.structureType) detalii.push({ label: 'Structură', value: prop.data.structureType });
if (prop.data.confortClass) detalii.push({ label: 'Confort', value: prop.data.confortClass });
if (prop.data.balconies) detalii.push({ label: 'Balcoane', value: `${prop.data.balconies}${prop.data.balconySurface ? ` (${prop.data.balconySurface} mp)` : ''}` });
if (prop.data.intabulat === true) detalii.push({ label: 'Cadastru', value: 'Intabulat' });
if (prop.data.availableFrom) detalii.push({ label: 'Disponibil din', value: prop.data.availableFrom });

// === Per-type extra characteristics (from CMS object groups) → friendly labels ===
const CHAR_LABELS: Record<string, string> = {
  // Apartament / bloc
  lift: 'Lift', centralaProprie: 'Centrală proprie', aerConditionat: 'Aer condiționat',
  interfon: 'Interfon / videointerfon', boxa: 'Boxă / pivniță', balconInchis: 'Balcon închis',
  // Casă
  curteImprejmuita: 'Curte împrejmuită', gradina: 'Grădină', garaj: 'Garaj',
  anexe: 'Anexe gospodărești', fosaSeptica: 'Fosă septică', panouriSolare: 'Panouri solare',
  putForat: 'Puț forat', terasa: 'Terasă',
  // Teren
  intravilan: 'Intravilan', extravilan: 'Extravilan', deschidereStradala: 'Deschidere stradală',
  utilitatiLaLimita: 'Utilități la limită', imprejmuit: 'Împrejmuit',
  // Comune (zonă / stradă)
  iluminatStradal: 'Iluminat stradal', stradaAsfaltata: 'Stradă asfaltată',
  stradaPietruita: 'Stradă pietruită', utilitatiLaStrada: 'Utilități la stradă',
  transportInComun: 'Transport în comun',
};
const charGroups = [prop.data.caracteristiciApartament, prop.data.caracteristiciCasa, prop.data.caracteristiciTeren];
const extraChars: string[] = [];
for (const grp of charGroups) {
  if (grp && typeof grp === 'object') {
    for (const [k, v] of Object.entries(grp as Record<string, unknown>)) {
      if (v === true && CHAR_LABELS[k]) extraChars.push(CHAR_LABELS[k]);
    }
  }
}
// Curăță prefixele de listă lăsate de client în textul liber ("-Ferestre", "• Boxă", "– 2 băi")
// — doar la afișare, fișierele .md rămân neatinse.
const cleanFeature = (s: string) => s.replace(/^[\s\-–—•·*▪◦]+/, '').trim();
// Merge free-text features + structured per-type characteristics, dedupe.
const allFeatures = Array.from(new Set([
  ...(prop.data.features || []).map(cleanFeature).filter(Boolean),
  ...extraChars,
]));

// Inquiry / contact strings now carry the listing code.
const contactWithId = `/contact/?proprietate=${encodeURIComponent(prop.data.title)}&id=${encodeURIComponent(lid)}`;
const waMsgWithId = `Bună ziua! Vreau informații despre proprietatea: ${prop.data.title} (cod ${lid})`;
---

<Layout
	title={`${prop.data.title} | Casa Mult Visată Piatra Neamț`}
	description={metaDescription}
	ogImage={absoluteOgImage}
	preloadImage={cdnImg(imageSrc, { w: 1200 })}
	preloadImageSrcset={cdnSrcset(imageSrc, [600, 900, 1200, 1600])}
	preloadImageSizes="(max-width: 900px) 100vw, 1100px"
	noIndex={isFaded}
>

	<link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.4/dist/photoswipe.css" crossorigin />

	<div class={`container property-detail${isFaded ? ' is-faded' : ''}`} style="padding-top: 3rem;" data-listing-status={listingStatus}>
        <div style="margin-bottom: 2rem;">
            <a href="/proprietati" style="font-family: var(--font-accent); font-size: 0.8125rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary);">&larr; Înapoi la proprietăți</a>
        </div>

		<div class="about-editorial">
			<div class="body-text">
                <!-- TAGURI CLICKABILE (status + tip) → listări filtrate -->
                <div class="prop-tags">
                    <a class="prop-tag" href={statusHref}>{prop.data.status}</a>
                    <a class="prop-tag" href={typeHref}>{prop.data.propertyType}</a>
                    {prop.data.exclusive && <span class="badge badge-exclusiv">Exclusiv</span>}
                    {prop.data.comisionZero && <span class="badge badge-comision-zero">Comision 0%</span>}
                </div>
                <div class="title-row">
                    <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 1.5rem + 2vw, 3.5rem); font-weight: 300; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1rem;">{prop.data.title}</h1>
                    {listingStatus && listingStatus !== 'Activ' && (
                        <span class={`status-pill status-pill--${listingStatus === 'Vândut' ? 'vandut' : listingStatus === 'Închiriat' ? 'inchiriat' : listingStatus === 'Rezervat' ? 'rezervat' : 'retras'}`}>{listingStatus}</span>
                    )}
                </div>
                <!-- LOCAȚIE CLICKABILĂ (oraș · zonă · stradă) → listări filtrate -->
                <p class="prop-location">
                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <a href={locHref}>{prop.data.location}</a>
                    {zoneHref && <>{' · '}<a href={zoneHref}>{effZone}</a></>}
                    {streetHref && <>{' · '}<a href={streetHref}>{prop.data.street}</a></>}
                </p>
                {updatedAtFormatted && (
                    <p class="updated-stamp">Actualizat la {updatedAtFormatted}</p>
                )}

                <div class={`hero-image-wrap${isFaded ? ' has-watermark' : ''}`} data-has-gallery={images.length > 1 ? "true" : "false"}>
                    {isFaded && (
                        <span class="hero-watermark" aria-hidden="true">{listingStatus === 'Vândut' ? 'VÂNDUT' : listingStatus === 'Închiriat' ? 'ÎNCHIRIAT' : 'RETRAS'}</span>
                    )}
                    <img
                            id="hero-image"
                            src={cdnImg(imageSrc, { w: 1200 })}
                            srcset={cdnSrcset(imageSrc, [600, 900, 1200, 1600])}
                            sizes="(max-width: 900px) 100vw, 1100px"
                            alt={prop.data.title}
                            width="1200"
                            height="800"
                            fetchpriority="high"
                            decoding="async"
                            data-index="0"
                        >
                    {images.length > 1 && (
                        <button type="button" class="hero-zoom-hint" aria-label="Deschide galeria în mod ecran complet">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
                            <span>Mărește · {images.length} foto</span>
                        </button>
                    )}
                </div>

                {images.length > 1 && (
                    <section id="pswp-gallery" class="gallery-grid" aria-label="Galerie foto" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.5rem; margin-bottom: 2rem;">
                        {images.map((src, i) => {
                            const [w, h] = getDims(src);
                            const lw = Math.min(w, 1600);
                            const lh = Math.round(h * lw / w);
                            const full = cdnImg(src, { w: lw });
                            return (
                            <a
                                href={full}
                                data-pswp-src={full}
                                data-pswp-srcset={`${full} ${lw}w`}
                                data-pswp-width={lw}
                                data-pswp-height={lh}
                                class={`gallery-item ${i === 0 ? 'is-active' : ''}`}
                                data-index={i}
                                aria-label={`Vezi imaginea ${i + 1}`}
                            >
                                <img src={cdnImg(src, { w: 320, h: 240 })} srcset={cdnSrcset(src, [160, 320, 480])} sizes="160px" alt={`${prop.data.title} — imagine ${i + 1}`} width="160" height="120" loading="lazy" decoding="async" />
                            </a>);
                        })}
                    </section>
                )}

                <div class="share-row" aria-label="Distribuie această proprietate">
                    <span class="share-row__label">Distribuie:</span>
