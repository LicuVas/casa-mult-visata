---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allProps = await getCollection('proprietati');
  return allProps.map(prop => ({
    params: { slug: prop.id },
    props: { prop },
  }));
}

const { prop } = Astro.props;
const { Content } = await render(prop);

// Format price
const formatPrice = (price: number, currency: string) => {
  return new Intl.NumberFormat('ro-RO', { style: 'currency', currency: currency, maximumFractionDigits: 0 }).format(price);
};

const imageSrc = prop.data.featuredImage || (prop.data.propertyType === 'Apartament' ? '/images/apartament.png' : prop.data.propertyType === 'Casă' ? '/images/casa.png' : '/images/teren.png');

// Contact strings
const contactPhone = "0747814263";
const displayPhone = "0747 814 263";
const whatsappMsg = `Bună ziua! Vreau informații despre proprietatea: ${prop.data.title}`;
---

<Layout title={`${prop.data.title} | Casa Mult Visată Piatra Neamț`} description={`${prop.data.propertyType} de ${prop.data.status.toLowerCase()} în ${prop.data.location}. ${prop.data.price ? formatPrice(prop.data.price, prop.data.currency) : ''}`}>
	
	<div class="container" style="padding-top: 3rem;">
        <div style="margin-bottom: 2rem;">
            <a href="/proprietati" style="font-family: var(--font-accent); font-size: 0.8125rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary);">&larr; Înapoi la proprietăți</a>
        </div>

		<div class="about-editorial reveal">
			<div class="body-text">
                <span class="tag" style="font-family: var(--font-accent); font-variant: small-caps; letter-spacing: var(--letter-spacing-caps); text-transform: lowercase; font-size: 0.875rem; color: var(--accent); display: block; margin-bottom: 0.5rem;">
                    De {prop.data.status.toLowerCase()} 
                    {prop.data.exclusive ? " · Exclusiv" : ""}
                    {prop.data.comisionZero ? " · Comision 0%" : ""}
                </span>
				<h1 style="font-family: var(--font-display); font-size: clamp(2rem, 1.5rem + 2vw, 3.5rem); font-weight: 300; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1rem;">{prop.data.title}</h1>
                <p style="font-family: var(--font-accent); font-size: 1.125rem; color: var(--text-secondary); margin-bottom: 2rem;">{prop.data.location}</p>

                <img src={imageSrc} alt={prop.data.title} style="width: 100%; aspect-ratio: 16/9; object-fit: cover; margin-bottom: 2rem;">

                <div style="font-size: 1.125rem; line-height: 1.8;">
                    <Content />
                </div>

                {prop.data.features && prop.data.features.length > 0 && (
                    <div style="margin-top: 3rem;">
                        <h3 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; margin-bottom: 1.5rem;">Caracteristici</h3>
                        <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                            {prop.data.features.map(feature => (
                                <li style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); position: relative; padding-left: 1.25rem;">
                                    <span style="position: absolute; left: 0; color: var(--accent-green); font-weight: 600;">✓</span>
                                    {feature}
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
			</div>
            
			<aside class="sidebar" style="position: sticky; top: 100px;">
                <div style="background: var(--surface-secondary); padding: 2rem; margin-bottom: 2rem;">
                    <h4 style="margin-top:0;">Preț</h4>
                    <div class="stat">
                        <span class="stat-number" style="font-size: 2rem;">{prop.data.pricePerUnit ? prop.data.pricePerUnit : formatPrice(prop.data.price, prop.data.currency)}</span>
                        {prop.data.comisionZero && <span class="stat-label" style="color: var(--accent-green); font-weight: 600; display:block; margin-top:0.5rem;">COMISION 0% CUMPĂRĂTOR</span>}
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 2rem 0;">
                        {prop.data.propertyType && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Tip</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.propertyType}</span>
                            </div>
                        )}
                        {prop.data.surface && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Suprafață</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.surface} mp</span>
                            </div>
                        )}
                        {prop.data.landSurface && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Teren</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.landSurface} mp</span>
                            </div>
                        )}
                        {prop.data.rooms && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Camere</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.rooms}</span>
                            </div>
                        )}
                        {prop.data.bathrooms && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Băi</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.bathrooms}</span>
                            </div>
                        )}
                        {prop.data.floor && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">Etaj</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.floor}</span>
                            </div>
                        )}
                        {prop.data.yearBuilt && (
                            <div>
                                <h4 style="font-size: 0.75rem; margin-bottom: 0.25rem;">An</h4>
                                <span style="font-family: var(--font-body); font-weight: 500;">{prop.data.yearBuilt}</span>
                            </div>
                        )}
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        <a href={`tel:${contactPhone}`} class="btn-primary" style="text-align: center;">Sună Agentul</a>
                        <a href={`https://wa.me/40${contactPhone.substring(1)}?text=${encodeURIComponent(whatsappMsg)}`} class="btn-whatsapp" target="_blank" rel="noopener" style="justify-content: center;">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                            Mesaj pe WhatsApp
                        </a>
                        <a href="/contact" style="font-family: var(--font-accent); font-size: 0.875rem; font-weight: 500; text-align: center; color: var(--accent); border: 2px solid var(--accent); padding: 0.75rem 1.5rem; transition: 0.2s;">Programează Vizionare</a>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 1rem;">
                    <img src="/images/agent.png" alt="Cozma Vasile" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
                    <div>
                        <span style="font-family: var(--font-accent); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); display: block;">Agent Imobiliar</span>
                        <span style="font-family: var(--font-body); font-weight: 500; display: block;">Cozma Vasile</span>
                    </div>
                </div>
			</aside>
		</div>
	</div>

</Layout>
