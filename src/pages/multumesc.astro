---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mulțumesc · Casa Mult Visată" description="Mesajul tău a fost trimis cu succes. Cozma Vasile te va contacta în cel mai scurt timp.">

	<section style="padding: var(--section-padding);">
		<div class="container">
			<div class="page-header reveal" style="text-align:center; max-width:42rem; margin:0 auto;">
				<p class="label">Mesaj primit</p>
				<h1 style="font-family:var(--font-display); font-weight:300;">
					<span style="color:var(--accent-green);">Mulțumesc</span> pentru mesaj
				</h1>
				<p class="intro" style="margin-top:1.5rem;">
					Mesajul tău a ajuns la mine. Te voi contacta în cel mai scurt timp posibil — de obicei în câteva ore, în timpul programului.
				</p>
				<p style="font-family:var(--font-accent); color:var(--text-secondary); margin-top:1rem;">
					Dacă e ceva urgent, mă poți suna sau scrie pe WhatsApp imediat.
				</p>

				<div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:2.5rem;">
					<a href="/" class="btn-primary">Înapoi acasă</a>
					<a href="https://wa.me/40747814263?text=Bună%20ziua!%20Tocmai%20am%20trimis%20un%20mesaj%20prin%20site." class="btn-primary" style="background:var(--accent-green);" target="_blank" rel="noopener noreferrer">Scrie pe WhatsApp</a>
				</div>

				<p style="margin-top:3rem; font-family:var(--font-accent); color:var(--text-secondary); font-size:0.95rem;">
					Sau sună direct: <a href="tel:0747814263" style="color:var(--accent); text-decoration:none; font-weight:500;">0747 814 263</a>
				</p>
			</div>
		</div>
	</section>

</Layout>
