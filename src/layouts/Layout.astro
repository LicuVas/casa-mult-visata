---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Agenție imobiliară de încredere în Piatra Neamț. Apartamente, case, terenuri — vânzare și închiriere. Agent Cozma Vasile." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ro">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
		
		<link rel="stylesheet" href="/style.css" />

		<!-- Netlify Identity Widget -->
		<script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Salt la conținut</a>

		<!-- HEADER -->
		<header class="masthead" role="banner">
			<div class="container">
				<div class="masthead-top">
					<span class="date">Piatra Neamț, Neamț</span>
					<a href="/" class="masthead-logo">Casa Mult Visată</a>
					<a href="tel:0747814263" class="date phone-header">📞 0747 814 263</a>
				</div>
				<nav aria-label="Navigare principală" style="position:relative;">
					<button class="mobile-toggle" aria-label="Meniu" aria-expanded="false" onclick="this.nextElementSibling.classList.toggle('open');this.setAttribute('aria-expanded',this.nextElementSibling.classList.contains('open'))">
						<span></span><span></span><span></span>
					</button>
					<ul class="masthead-nav">
						<li><a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Acasă</a></li>
						<li><a href="/proprietati" aria-current={currentPath.startsWith('/proprietati') ? 'page' : undefined}>Proprietăți</a></li>
						<li><a href="/servicii" aria-current={currentPath === '/servicii' ? 'page' : undefined}>Servicii</a></li>
						<li><a href="/despre" aria-current={currentPath === '/despre' ? 'page' : undefined}>Despre Mine</a></li>
						<li><a href="/contact" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a></li>
					</ul>
				</nav>
			</div>
		</header>

		<main id="main-content">
			<slot />
		</main>

		<!-- FOOTER -->
		<footer class="footer-editorial">
			<div class="container">
				<div class="footer-grid">
					<div>
						<div class="footer-brand">Casa Mult Visată</div>
						<p class="footer-desc">Agent imobiliar. Dedicare, seriozitate și rezultate în Piatra Neamț.</p>
						<a href="https://wa.me/40747814263?text=Bună%20ziua!%20Vreau%20informații." class="whatsapp-link" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							Scrie-mi pe WhatsApp
						</a>
					</div>
					<div>
						<h4>Pagini</h4>
						<ul>
							<li><a href="/">Acasă</a></li>
							<li><a href="/proprietati">Proprietăți</a></li>
							<li><a href="/servicii">Servicii</a></li>
							<li><a href="/despre">Despre Mine</a></li>
							<li><a href="/contact">Contact</a></li>
						</ul>
					</div>
					<div>
						<h4>Contact</h4>
						<ul>
							<li>Piatra Neamț, Neamț</li>
							<li><a href="tel:0747814263">0747 814 263</a></li>
							<li><a href="mailto:vascozma@gmail.com">vascozma@gmail.com</a></li>
						</ul>
					</div>
					<div>
						<h4>Social Media</h4>
						<ul>
							<li><a href="https://www.facebook.com/profile.php?id=100075290402563" target="_blank" rel="noopener">Facebook</a></li>
							<li><a href="https://www.instagram.com/cozma276/" target="_blank" rel="noopener">Instagram</a></li>
							<li><a href="https://www.tiktok.com/@cozmavasile_si_ana_lory" target="_blank" rel="noopener">TikTok</a></li>
						</ul>
					</div>
				</div>
				<div class="footer-bottom">
					<span>&copy; {new Date().getFullYear()} Casa Mult Visată — Cozma Vasile. Toate drepturile rezervate.</span>
					<span>Piatra Neamț, România</span>
				</div>
			</div>
		</footer>

		<!-- FLOATING WHATSAPP -->
		<a href="https://wa.me/40747814263?text=Bună%20ziua!%20Am%20văzut%20site-ul%20și%20vreau%20informații." class="whatsapp-float" target="_blank" rel="noopener" aria-label="Contactează pe WhatsApp">
			<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
		</a>

		<script is:inline>
		(function(){
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
			const obs = new IntersectionObserver(function(entries){
				entries.forEach(function(e){
					if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
				});
			}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
			document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });
		})();

		// Setup Netlify Identity redirect
		if (window.netlifyIdentity) {
			window.netlifyIdentity.on("init", user => {
				if (!user) {
					window.netlifyIdentity.on("login", () => {
						document.location.href = "/admin/";
					});
				}
			});
		}
		</script>
	</body>
</html>
