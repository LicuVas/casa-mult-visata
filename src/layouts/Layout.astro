---
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	canonicalPath?: string;
	noIndex?: boolean;
	preloadImage?: string;
	preloadImageSrcset?: string;
	preloadImageSizes?: string;
	extraSchema?: Record<string, unknown>;
}

const {
	title,
	description = "Agenție imobiliară de încredere în Piatra Neamț. Apartamente, case, terenuri — vânzare și închiriere. Agent Cozma Vasile.",
	ogImage = "/sistem/hero.webp",
	canonicalPath,
	noIndex = false,
	preloadImage,
	preloadImageSrcset,
	preloadImageSizes,
	extraSchema,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://casamultvisata.ro";
const canonicalUrl = canonicalPath
	? `${siteOrigin}${canonicalPath.startsWith("/") ? canonicalPath : "/" + canonicalPath}`
	: `${siteOrigin}${currentPath}`;
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${siteOrigin}${ogImage.startsWith("/") ? ogImage : "/" + ogImage}`;

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "RealEstateAgent",
			"@id": `${siteOrigin}/#agent`,
			"name": "Cozma Vasile",
			"legalName": "COZMA I. VASILE P.F.A.",
			"taxID": "50412580",
			"brand": {
				"@type": "Brand",
				"name": "Casa Mult Visată"
			},
			"image": absoluteOgImage,
			"url": siteOrigin,
			"telephone": "+40747814263",
			"email": "vascozma@gmail.com",
			"areaServed": {
				"@type": "City",
				"name": "Piatra Neamț"
			},
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Piatra Neamț",
				"addressRegion": "Neamț",
				"addressCountry": "RO"
			},
			"sameAs": [
				"https://www.facebook.com/profile.php?id=100075290402563",
				"https://www.instagram.com/cozma276/",
				"https://www.tiktok.com/@cozmavasile_si_ana_lory"
			]
		},
		{
			"@type": "LocalBusiness",
			"@id": `${siteOrigin}/#business`,
			"name": "Casa Mult Visată",
			"image": absoluteOgImage,
			"url": siteOrigin,
			"telephone": "+40747814263",
			"email": "vascozma@gmail.com",
			"priceRange": "€€",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Piatra Neamț",
				"addressRegion": "Neamț",
				"addressCountry": "RO"
			},
			"areaServed": "Piatra Neamț"
		},
		{
			"@type": "Organization",
			"@id": `${siteOrigin}/#organization`,
			"name": "Casa Mult Visată",
			"url": siteOrigin,
			"logo": absoluteOgImage
		},
		{
			"@type": "WebSite",
			"@id": `${siteOrigin}/#website`,
			"url": siteOrigin,
			"name": "Casa Mult Visată",
			"inLanguage": "ro-RO",
			"publisher": { "@id": `${siteOrigin}/#organization` },
			"potentialAction": {
				"@type": "SearchAction",
				"target": {
					"@type": "EntryPoint",
					"urlTemplate": `${siteOrigin}/proprietati?q={search_term_string}`
				},
				"query-input": "required name=search_term_string"
			}
		}
	]
};
