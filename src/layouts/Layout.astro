		<link rel="stylesheet" href="/style.css" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		{extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

